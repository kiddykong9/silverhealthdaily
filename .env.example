# Copy to .env for local dev; set same vars in Vercel/Cloudflare dashboard for production

# USDA FoodData Central — free key at https://fdc.nal.usda.gov/api-key-signup.html
# Required for food search on /tools/food-calorie-calculator (falls back to DEMO_KEY with strict rate limits)
USDA_API_KEY=your_usda_api_key_here

# Google AdSense (after approval)
# PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google Analytics 4 — create at analytics.google.com → Admin → Data Streams
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
