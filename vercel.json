{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.silverhealthdaily.com" }],
      "destination": "https://silverhealthdaily.com/:path*",
      "permanent": true
    }
  ]
}
