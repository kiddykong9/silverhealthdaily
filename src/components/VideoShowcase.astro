---
import { WELLNESS_VIDEOS } from '../lib/media';
import SectionHeading from './SectionHeading.astro';
import ScrollReveal from './ScrollReveal.astro';
import YouTubeEmbed from './YouTubeEmbed.astro';
---

<section id="wellness-videos" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
  <ScrollReveal>
    <SectionHeading
      label="Watch & learn"
      title="Free exercise videos for adults 50+"
      description="Official guided workouts from the U.S. National Institute on Aging — click play, follow along at home."
      centered
    />
  </ScrollReveal>

  <div class="grid gap-8 md:grid-cols-3">
    {
      WELLNESS_VIDEOS.map((clip, i) => (
        <ScrollReveal delay={i * 120}>
          <article class="overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-sage-100">
            <YouTubeEmbed youtubeId={clip.youtubeId} title={clip.title} />
            <div class="p-5">
              <div class="mb-2 flex items-center justify-between gap-2">
                <span class="rounded-full bg-sage-100 px-2.5 py-0.5 text-xs font-semibold text-sage-800">
                  {clip.duration}
                </span>
                <span class="text-xs text-muted">{clip.channel}</span>
              </div>
              <h3 class="font-display text-lg font-bold text-ink">{clip.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-muted">{clip.description}</p>
            </div>
          </article>
        </ScrollReveal>
      ))
    }
  </div>

  <p class="mt-8 text-center text-sm text-muted">
    Source:{' '}
    <a
      href="https://www.nia.nih.gov/health/exercise-and-physical-activity"
      class="font-medium text-sage-700 underline"
      target="_blank"
      rel="noopener noreferrer"
    >
      National Institute on Aging
    </a>
    — always consult your doctor before starting a new exercise program.
  </p>
</section>
