---
import type { CollectionEntry } from 'astro:content';
import { getCategory } from '../lib/site';
import { getArticleImage } from '../lib/media';
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  article: CollectionEntry<'articles'>;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;
const image = getArticleImage(article.data.category, article.id);
const category = getCategory(article.data.category);
const date = article.data.publishDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<article class="group card-lift overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-sage-100">
  <a href={`/articles/${article.id}/`} class="block">
    <div class="relative aspect-[16/10] overflow-hidden bg-sage-100">
      <OptimizedImage
        src={image.src}
        alt={image.alt}
        width={640}
        height={400}
        class="article-card-img h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-sage-900/80 via-transparent to-transparent" />
      {
        featured && (
          <span class="absolute right-4 top-4 rounded-full bg-gold px-3 py-1 text-xs font-bold uppercase tracking-wide text-sage-900">
            Featured
          </span>
        )
      }
      {
        category && (
          <span class="absolute bottom-4 left-4 rounded-full bg-white/95 px-3 py-1 text-xs font-semibold text-sage-800 shadow-sm backdrop-blur">
            {category.name}
          </span>
        )
      }
    </div>

    <div class="p-6">
      <p class="mb-2 text-xs font-medium text-muted">{article.data.readTime} min read</p>
      <h2 class="font-display mb-2 text-xl font-bold leading-snug text-ink group-hover:text-sage-700">
        {article.data.title}
      </h2>
      <p class="mb-4 line-clamp-2 text-sm leading-relaxed text-muted">
        {article.data.description}
      </p>
      <time datetime={article.data.publishDate.toISOString()} class="text-xs font-medium text-sage-600">
        {date}
      </time>
    </div>
  </a>
</article>
