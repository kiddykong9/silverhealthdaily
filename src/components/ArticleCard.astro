---
import type { CollectionEntry } from 'astro:content';
import { getCategoryImage, getArticleImage } from '../lib/media';

interface Props {
  article: CollectionEntry<'articles'>;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;
const image = getArticleImage(article.data.category, article.id);
const category = article.data.category;
const date = article.data.publishDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const categoryLabels: Record<string, { name: string; icon: string }> = {
  nutrition: { name: 'Nutrition', icon: '🥗' },
  fitness: { name: 'Fitness', icon: '🚶' },
  sleep: { name: 'Sleep', icon: '🌙' },
  'heart-health': { name: 'Heart Health', icon: '❤️' },
  'brain-memory': { name: 'Brain & Memory', icon: '🧠' },
  wellness: { name: 'Wellness', icon: '✨' },
};
const catLabel = categoryLabels[category];
---

<article
  class:list={[
    'group card-lift overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-sage-100',
    featured && 'md:col-span-1',
  ]}
>
  <a href={`/articles/${article.id}`} class="block">
    <div class="relative aspect-[16/10] overflow-hidden">
      <img
        src={image.src}
        alt={image.alt}
        width="640"
        height="400"
        class="article-card-img h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-sage-900/75 via-sage-900/10 to-transparent" />
      {
        featured && (
          <span class="absolute right-4 top-4 rounded-full bg-gold/90 px-3 py-1 text-xs font-bold uppercase tracking-wide text-sage-900 shadow">
            Featured
          </span>
        )
      }
      {
        catLabel && (
          <span class="absolute bottom-4 left-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-sage-800 backdrop-blur">
            {catLabel.icon} {catLabel.name}
          </span>
        )
      }
    </div>

    <div class="p-6">
      <div class="mb-2 flex items-center gap-2">
        <span class="text-xs font-medium text-muted">{article.data.readTime} min read</span>
      </div>
      <h2 class="font-display mb-2 text-xl font-bold leading-snug text-ink group-hover:text-sage-700">
        {article.data.title}
      </h2>
      <p class="mb-4 line-clamp-2 text-sm leading-relaxed text-muted">
        {article.data.description}
      </p>
      <time datetime={article.data.publishDate.toISOString()} class="text-xs font-medium text-sage-600">
        {date}
      </time>
    </div>
  </a>
</article>
