---
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES } from '../lib/site';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const category = CATEGORIES.find((c) => c.slug === article.data.category);
const date = article.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-md">
  <a href={`/articles/${article.id}`} class="block p-6">
    <div class="mb-3 flex flex-wrap items-center gap-2 text-sm">
      {
        category && (
          <span class="rounded-full bg-brand-50 px-3 py-1 font-medium text-brand-700">
            {category.name}
          </span>
        )
      }
      <span class="text-muted">{article.data.readTime} min read</span>
    </div>
    <h2 class="mb-2 text-xl font-bold text-stone-900 group-hover:text-brand-800">
      {article.data.title}
    </h2>
    <p class="mb-4 line-clamp-3 text-stone-600">{article.data.description}</p>
    <time datetime={article.data.publishDate.toISOString()} class="text-sm text-muted">
      {date}
    </time>
  </a>
</article>
