---
interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
  dark?: boolean;
}

const { label, title, description, centered = false, dark = false } = Astro.props;
const align = centered ? 'text-center mx-auto' : '';
---

<div class={`mb-10 max-w-2xl ${align}`}>
  {label && <p class:list={['section-label', dark && '!text-gold-light']}>{label}</p>}
  <h2 class:list={['section-title', dark && '!text-white']}>{title}</h2>
  {description && <p class:list={['mt-3 text-lg', dark ? 'text-sage-200' : 'text-muted']}>{description}</p>}
</div>
