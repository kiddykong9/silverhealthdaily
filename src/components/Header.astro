---
import { SITE, NAV_LINKS } from '../lib/site';
---

<header class="sticky top-0 z-50 border-b border-stone-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6">
    <a href="/" class="group flex min-w-0 flex-col">
      <span class="truncate text-xl font-bold tracking-tight text-brand-800 sm:text-2xl">
        {SITE.name}
      </span>
      <span class="hidden text-sm text-muted sm:block">{SITE.tagline}</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="font-medium text-stone-700 transition hover:text-brand-700"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <a
      href="/articles"
      class="rounded-full bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-700 md:hidden"
    >
      Read
    </a>
  </div>
</header>
