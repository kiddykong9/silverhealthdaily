---
import { SITE, NAV_LINKS } from '../lib/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-sage-100/80 bg-cream/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 sm:py-4">
    <a href="/" class="group flex items-center gap-3 min-w-0">
      <img
        src="/logo.png"
        alt={`${SITE.name} logo`}
        width="44"
        height="44"
        class="h-11 w-11 shrink-0 rounded-full ring-1 ring-sage-200 object-cover transition group-hover:scale-[1.02]"
      />
      <span class="min-w-0">
        <span class="font-display block truncate text-lg font-bold leading-tight text-sage-900 sm:text-xl">
          {SITE.name}
        </span>
        <span class="hidden text-xs font-medium text-gold sm:block">{SITE.tagline}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Main">
      {
        NAV_LINKS.map((link) => {
          const active = currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              class:list={[
                'rounded-full px-4 py-2 text-sm font-semibold transition',
                active
                  ? 'bg-sage-100 text-sage-800'
                  : 'text-ink-soft hover:bg-sage-50 hover:text-sage-800',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <a href="/articles" class="btn-primary hidden !px-5 !py-2.5 !text-sm sm:inline-flex">
        Start reading
      </a>
      <a
        href="/articles"
        class="btn-primary !px-4 !py-2 !text-sm sm:hidden"
      >
        Read
      </a>
    </div>
  </div>
</header>
