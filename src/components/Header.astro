---
import { SITE, NAV_LINKS } from '../lib/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-sage-100/80 bg-cream/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-3 sm:px-6 sm:py-3.5">
    <a href="/" class="group shrink-0">
      <img
        src="/brand-logo.png"
        alt={SITE.name}
        width="879"
        height="179"
        class="h-9 w-auto object-contain object-left transition group-hover:opacity-90 sm:h-12 md:h-14"
        decoding="async"
      />
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-1 lg:flex" aria-label="Main">
      {
        NAV_LINKS.map((link) => {
          const active = currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              class:list={[
                'rounded-full px-4 py-2 text-sm font-semibold transition',
                active
                  ? 'bg-sage-100 text-sage-800'
                  : 'text-ink-soft hover:bg-sage-50 hover:text-sage-800',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <a href="/articles" class="btn-primary !px-4 !py-2 !text-sm sm:!px-5 sm:!py-2.5">
        Start reading
      </a>
    </div>
  </div>
</header>
