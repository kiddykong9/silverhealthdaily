---
interface Props {
  href: string;
  title: string;
  blurb: string;
}

const { href, title, blurb } = Astro.props;
---

<div class="not-prose mb-8 rounded-2xl border border-sage-200 bg-gradient-to-br from-sage-50 to-white p-6 shadow-sm ring-1 ring-sage-100">
  <p class="text-xs font-bold uppercase tracking-wide text-sage-600">Free calculator</p>
  <h2 class="font-display mt-1 text-xl font-bold text-sage-900 sm:text-2xl">{title}</h2>
  <p class="mt-2 text-sm leading-relaxed text-ink-soft">{blurb}</p>
  <a
    href={href}
    class="mt-4 inline-flex items-center gap-2 rounded-full bg-sage-700 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-sage-800"
  >
    Open calculator
    <span aria-hidden="true">→</span>
  </a>
</div>
