---
import { HERO, CATEGORY_IMAGES } from '../lib/media';
import OptimizedImage from './OptimizedImage.astro';

const inset = CATEGORY_IMAGES.nutrition;
const feature = CATEGORY_IMAGES.wellness;
---

<section class="relative min-h-[88vh] overflow-hidden lg:min-h-[92vh]">
  <div class="absolute inset-0" aria-hidden="true">
    <OptimizedImage
      src={HERO.src}
      alt=""
      width={1800}
      height={1000}
      class="hero-ken-burns h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-sage-900/94 via-sage-900/82 to-sage-900/50" />
    <div class="absolute inset-0 bg-gradient-to-t from-sage-900/50 via-transparent to-sage-900/15" />
  </div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-2 lg:py-28">
    <div class="reveal reveal-up" data-reveal>
      <p class="section-label !text-gold-light">Trusted health guides · Everyday wellness</p>
      <h1 class="font-display text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-[3.25rem]">
        Clear health advice for a healthier life
      </h1>
      <p class="mt-6 max-w-lg text-lg leading-relaxed text-white/90">
        Nutrition, fitness, sleep, and heart health — practical guides you can read in minutes,
        whether you're starting out or leveling up your routine.
      </p>
      <div class="mt-9 flex flex-wrap gap-4">
        <a href="/tools/food-calorie-calculator" class="btn-primary">Use free calculators</a>
        <a href="/articles" class="btn-secondary !border-white/25 !bg-white/10 !text-white hover:!bg-white/20">
          Browse health guides
        </a>
      </div>
    </div>

    <div class="relative hidden lg:block">
      <div class="reveal reveal-right relative overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/20" data-reveal style="--reveal-delay: 120ms">
        <OptimizedImage
          src={feature.src.replace('w=800', 'w=900')}
          alt={feature.alt}
          width={640}
          height={480}
          class="h-[420px] w-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-sage-900/55 to-transparent" />
      </div>
      <div class="reveal reveal-up absolute -bottom-4 -left-4 overflow-hidden rounded-2xl shadow-xl ring-2 ring-white/30" data-reveal style="--reveal-delay: 240ms">
        <OptimizedImage
          src={inset.src.replace('w=800', 'w=400')}
          alt={inset.alt}
          width={160}
          height={160}
          class="h-28 w-28 object-cover"
        />
      </div>
    </div>
  </div>
</section>
