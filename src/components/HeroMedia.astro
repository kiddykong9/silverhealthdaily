---
import { HERO } from '../lib/media';
---

<section class="relative min-h-[85vh] overflow-hidden lg:min-h-[90vh]">
  <!-- Ken Burns photo background (no broken hotlinked video) -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src={HERO.src}
      alt=""
      class="hero-ken-burns h-full w-full object-cover"
      width="1600"
      height="900"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-sage-900/93 via-sage-900/78 to-sage-900/45"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-sage-900/55 via-transparent to-sage-900/20"></div>
  </div>

  <div class="hero-float absolute right-[8%] top-[18%] h-28 w-28 rounded-full bg-gold/15 blur-2xl" aria-hidden="true"></div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-2 lg:py-28">
    <div class="reveal reveal-up" data-reveal>
      <p class="section-label !text-gold-light">
        <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-gold-light"></span>
        Health for adults 50+
      </p>
      <h1 class="font-display text-4xl font-bold leading-[1.12] tracking-tight text-white sm:text-5xl lg:text-[3.4rem]">
        Live longer,
        <span class="text-gold-light"> feel stronger</span>
      </h1>
      <p class="mt-6 max-w-lg text-lg leading-relaxed text-white/88">
        Practical guides on nutrition, walking, sleep, and heart health — written for real life after
        50, not fitness influencers half your age.
      </p>
      <div class="mt-9 flex flex-wrap gap-4">
        <a href="/articles" class="btn-primary hero-btn">
          Start reading
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#wellness-videos" class="btn-secondary !border-white/30 !bg-white/10 !text-white backdrop-blur hover:!bg-white/20">
          Watch free videos
        </a>
      </div>
    </div>

    <div class="relative hidden lg:block">
      <div
        class="reveal reveal-right overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/25"
        data-reveal
        style="--reveal-delay: 150ms"
      >
        <img
          src={HERO.src}
          alt={HERO.alt}
          width="640"
          height="480"
          class="h-[440px] w-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-sage-900/60 to-transparent"></div>
        <div class="absolute bottom-5 left-5 right-5 rounded-xl bg-white/10 p-4 backdrop-blur-md ring-1 ring-white/20">
          <p class="text-sm font-medium text-white">{HERO.alt}</p>
        </div>
      </div>
      <div
        class="reveal reveal-up absolute -bottom-5 -left-5 overflow-hidden rounded-2xl shadow-xl ring-2 ring-white/40"
        data-reveal
        style="--reveal-delay: 300ms"
      >
        <img
          src="https://images.unsplash.com/photo-1588874960056-07aa3d0afa3b?auto=format&fit=crop&w=400&q=80"
          alt="Senior woman preparing healthy food"
          width="180"
          height="180"
          class="h-32 w-32 object-cover"
          loading="lazy"
        />
      </div>
      <div
        class="reveal reveal-up absolute -right-4 top-6 rounded-2xl bg-white px-5 py-4 shadow-xl"
        data-reveal
        style="--reveal-delay: 450ms"
      >
        <p class="font-display text-3xl font-bold text-sage-800">50+</p>
        <p class="text-xs font-semibold text-muted">Written for you</p>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce text-white/40" aria-hidden="true">
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
