---
import { LIFESTYLE_GALLERY } from '../lib/media';
import SectionHeading from './SectionHeading.astro';
import ScrollReveal from './ScrollReveal.astro';
import OptimizedImage from './OptimizedImage.astro';
---

<section class="border-y border-sage-100 bg-white py-16 lg:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <ScrollReveal>
      <SectionHeading
        label="Real life, real health"
        title="Small habits that add up"
        description="Walking, cooking, reading, connecting — everyday choices that support long-term wellbeing."
        centered
      />
    </ScrollReveal>

    <div class="mt-10 grid grid-cols-2 gap-4 lg:grid-cols-4">
      {
        LIFESTYLE_GALLERY.map((photo, i) => (
          <ScrollReveal delay={i * 80}>
            <figure class="group relative aspect-[4/5] overflow-hidden rounded-2xl bg-sage-100">
              <OptimizedImage
                src={photo.src}
                alt={photo.alt}
                width={400}
                height={500}
                class="gallery-img h-full w-full object-cover"
              />
              <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-sage-900/85 to-transparent px-4 pb-4 pt-16">
                <span class="font-display text-lg font-bold text-white">{photo.caption}</span>
              </figcaption>
            </figure>
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</section>
