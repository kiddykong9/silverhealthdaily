---
import { TOOLS, getToolsForCategory } from '../lib/tools';

interface Props {
  current?: string;
  category?: string;
}

const { current, category } = Astro.props;
const tools = category ? getToolsForCategory(category) : TOOLS;
const heading = category ? 'Recommended tools' : 'Free health tools';
---

<div class="overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-sage-100">
  <div class="bg-sage-700 px-5 py-4">
    <p class="font-display font-bold text-white">{heading}</p>
  </div>
  <ul class="max-h-80 space-y-0.5 overflow-y-auto p-3 text-sm">
    {
      tools.map((tool) => (
        <li>
          <a
            href={tool.href}
            class:list={[
              'block rounded-lg px-3 py-2 font-medium transition',
              current === tool.href
                ? 'bg-sage-100 text-sage-900'
                : 'text-ink-soft hover:bg-sage-50 hover:text-sage-800',
            ]}
          >
            {tool.title}
          </a>
        </li>
      ))
    }
  </ul>
  <div class="border-t border-sage-100 px-4 py-3">
    <a href="/start" class="text-sm font-semibold text-sage-700 hover:text-sage-900">
      Get a personalized plan →
    </a>
  </div>
</div>
