---
import { getRelatedTools, TOOLS, type ToolSlug } from '../lib/tools';

interface Props {
  current: ToolSlug;
}

const { current } = Astro.props;
const related = getRelatedTools(current);
---

{
  related.length > 0 && (
    <section class="mt-8 rounded-2xl border border-sage-200 bg-gradient-to-br from-sage-50 to-cream p-6">
      <p class="text-xs font-semibold uppercase tracking-wide text-sage-600">Try these next</p>
      <h2 class="font-display mt-1 text-xl font-bold text-sage-900">Related free tools</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-3">
        {related.map((tool) => (
          <a
            href={tool.href}
            class="group flex flex-col rounded-xl border border-sage-200 bg-white p-4 transition hover:border-sage-400 hover:shadow-md"
          >
            <span class="font-semibold text-sage-900 group-hover:text-sage-700">{tool.title}</span>
            <span class="mt-1 flex-1 text-sm text-muted">{tool.reason}</span>
            <span class="mt-3 text-sm font-semibold text-sage-700 group-hover:text-sage-900">
              Open tool →
            </span>
          </a>
        ))}
      </div>
      <p class="mt-4 text-center text-sm">
        <a href="/tools" class="font-semibold text-sage-700 hover:text-sage-900">
          View all {TOOLS.length} free tools
        </a>
      </p>
    </section>
  )
}
