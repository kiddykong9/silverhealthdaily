---
import type { ToolSeoContent } from '../lib/tool-seo';

interface Props {
  content: ToolSeoContent;
  title: string;
}

const { content, title } = Astro.props;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<div class="tool-seo mt-10 border-t border-sage-100 pt-10">
  <h2 class="font-display mb-4 text-2xl font-bold text-ink">About this {title.toLowerCase()}</h2>
  <div class="prose max-w-none text-ink-soft">
    {content.intro.map((p) => <p>{p}</p>)}
  </div>

  <h3 class="font-display mt-8 mb-4 text-xl font-bold text-ink">Frequently asked questions</h3>
  <div class="space-y-4">
    {
      content.faqs.map((f) => (
        <details class="group rounded-xl border border-sage-100 bg-white p-4 open:shadow-sm">
          <summary class="cursor-pointer font-semibold text-ink marker:content-none">
            <span class="flex items-center justify-between gap-2">
              {f.q}
              <span class="text-sage-400 transition group-open:rotate-45">+</span>
            </span>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">{f.a}</p>
        </details>
      ))
    }
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
