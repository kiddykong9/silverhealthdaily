---
import { SITE } from '../lib/site';

export type Crumb = { label: string; href?: string };

interface Props {
  items: Crumb[];
  inverted?: boolean;
}

const { items, inverted = false } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, SITE.url).href } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class:list={['mb-6 text-sm', inverted && 'text-white/80']}>
  <ol class="flex flex-wrap items-center gap-1.5">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && <span aria-hidden="true" class={inverted ? 'text-white/40' : 'text-sage-300'}>/</span>}
          {item.href ? (
            <a
              href={item.href}
              class:list={[
                'font-medium transition',
                inverted ? 'text-white/90 hover:text-white' : 'text-sage-700 hover:text-sage-900',
              ]}
            >
              {item.label}
            </a>
          ) : (
            <span class:list={['font-medium', inverted ? 'text-white' : 'text-ink']}>{item.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
