<div
  id="cookie-banner"
  class="fixed inset-x-0 bottom-0 z-[100] hidden border-t border-stone-200 bg-white p-4 shadow-lg"
  role="dialog"
  aria-label="Cookie consent"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-stone-700">
      We use cookies for analytics and ads. See our
      <a href="/privacy" class="font-medium text-brand-700 underline">Privacy Policy</a>.
    </p>
    <div class="flex shrink-0 gap-3">
      <button
        id="cookie-decline"
        type="button"
        class="rounded-lg border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 hover:bg-stone-50"
      >
        Decline
      </button>
      <button
        id="cookie-accept"
        type="button"
        class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script>
  const KEY = 'shd_cookie_consent';
  const banner = document.getElementById('cookie-banner');
  const accept = document.getElementById('cookie-accept');
  const decline = document.getElementById('cookie-decline');

  if (banner && !localStorage.getItem(KEY)) {
    banner.classList.remove('hidden');
  }

  function closeBanner(value: string) {
    localStorage.setItem(KEY, value);
    banner?.classList.add('hidden');
    if (value === 'accepted') {
      window.dispatchEvent(new Event('shd:consent-accepted'));
    }
  }

  accept?.addEventListener('click', () => closeBanner('accepted'));
  decline?.addEventListener('click', () => closeBanner('declined'));
</script>
