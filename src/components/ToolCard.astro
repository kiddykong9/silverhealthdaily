---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon = '🧮' } = Astro.props;
---

<a
  href={href}
  class="group flex gap-4 rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition hover:border-brand-200 hover:shadow-md"
>
  <span class="text-3xl" aria-hidden="true">{icon}</span>
  <div>
    <h2 class="text-lg font-bold text-stone-900 group-hover:text-brand-800">{title}</h2>
    <p class="mt-1 text-stone-600">{description}</p>
  </div>
</a>
