---
import { getDailyTip } from '../lib/daily-tips';

const tip = getDailyTip();
---

<div class="mx-auto max-w-6xl px-4 sm:px-6">
  <div class="flex items-start gap-4 rounded-2xl border border-sage-200 bg-gradient-to-r from-sage-50 to-cream px-5 py-4 shadow-sm">
    <span
      class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-sage-700 text-sm font-bold text-white"
      aria-hidden="true"
    >
      Tip
    </span>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-sage-600">Daily wellness tip</p>
      <p class="mt-1 text-ink-soft leading-relaxed">{tip}</p>
    </div>
  </div>
</div>
