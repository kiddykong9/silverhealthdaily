---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ToolSidebar from '../components/ToolSidebar.astro';
import RelatedTools from '../components/RelatedTools.astro';
import ToolSeoContent from '../components/ToolSeoContent.astro';
import ToolRelatedArticles from '../components/ToolRelatedArticles.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../lib/site';
import { getToolOgImage } from '../lib/media';
import { getToolSeo } from '../lib/tool-seo';
import { getToolArticleSlugs } from '../lib/tool-articles';
import type { ToolSlug } from '../lib/tools';

interface Props {
  title: string;
  description: string;
  current: ToolSlug;
  heroClass?: string;
}

const { title, description, current, heroClass = 'from-sage-700 to-sage-900' } = Astro.props;

const canonicalUrl = new URL(current.endsWith('/') ? current : `${current}/`, SITE.url).href;
const ogImage = getToolOgImage(current);
const seo = getToolSeo(current);
const articleSlugs = getToolArticleSlugs(current);
const allArticles = await getCollection('articles');
const relatedArticles = articleSlugs
  .map((id) => allArticles.find((a) => a.id === id))
  .filter(Boolean) as typeof allArticles;

const webAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description,
  url: canonicalUrl,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
};
---

<BaseLayout title={title} description={description} canonical={canonicalUrl} ogImage={ogImage}>
  <script type="application/ld+json" set:html={JSON.stringify(webAppJsonLd)} />

  <section class:list={['bg-gradient-to-br py-12', heroClass]}>
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumbs
        inverted
        items={[
          { label: 'Home', href: '/' },
          { label: 'Tools', href: '/tools' },
          { label: title },
        ]}
      />
      <slot name="hero" />
      <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">{title}</h1>
      <p class="mt-2 text-white/85">
        <slot name="subtitle" />
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[1fr_280px]">
      <div>
        <slot />
        {seo && <ToolSeoContent content={seo} title={title} />}
        <ToolRelatedArticles articles={relatedArticles} />
        <RelatedTools current={current} />
        <AdSlot slot="4444444444" class="mt-8" />
      </div>
      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <ToolSidebar current={current} />
      </aside>
    </div>
  </div>
</BaseLayout>
