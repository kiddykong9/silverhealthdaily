---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import ToolSidebar from '../components/ToolSidebar.astro';
import RelatedTools from '../components/RelatedTools.astro';
import type { ToolSlug } from '../lib/tools';

interface Props {
  title: string;
  description: string;
  current: ToolSlug;
  heroClass?: string;
}

const { title, description, current, heroClass = 'from-sage-700 to-sage-900' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class:list={['bg-gradient-to-br py-12', heroClass]}>
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <slot name="hero" />
      <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">{title}</h1>
      <p class="mt-2 text-white/85">
        <slot name="subtitle" />
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[1fr_280px]">
      <div>
        <slot />
        <RelatedTools current={current} />
        <AdSlot slot="4444444444" class="mt-8" />
      </div>
      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <ToolSidebar current={current} />
      </aside>
    </div>
  </div>
</BaseLayout>
