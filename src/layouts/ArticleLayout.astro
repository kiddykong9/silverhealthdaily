---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ToolSidebar from '../components/ToolSidebar.astro';
import { SITE, getCategory } from '../lib/site';
import { getArticleImage } from '../lib/media';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  relatedArticles?: CollectionEntry<'articles'>[];
}

const { article, relatedArticles = [] } = Astro.props;
const { title, description, category, publishDate, updatedDate, readTime } = article.data;
const categoryMeta = getCategory(category);
const heroImage = getArticleImage(category, article.id);
const url = new URL(`/articles/${article.id}`, SITE.url).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: {
      '@type': 'ImageObject',
      url: SITE.logo,
    },
  },
  mainEntityOfPage: url,
  image: heroImage.src,
};
---

<BaseLayout title={title} description={description} canonical={url} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <header class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={heroImage.src.replace('w=800', 'w=1400')}
        alt=""
        class="h-full w-full object-cover"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-sage-900/95 via-sage-900/85 to-sage-900/70" />
      <div class:list={['absolute inset-0 opacity-30 mix-blend-multiply bg-gradient-to-br', categoryMeta?.gradient ?? 'from-sage-700 to-sage-900']} />
    </div>

    <div class="relative mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-20">
      {
        categoryMeta && (
          <a
            href={`/category/${categoryMeta.slug}`}
            class="mb-4 inline-flex items-center rounded-full bg-white/15 px-4 py-1.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/25"
          >
            {categoryMeta.name}
          </a>
        )
      }
      <h1 class="font-display text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-white/85">{description}</p>
      <p class="mt-6 flex flex-wrap items-center gap-3 text-sm text-white/70">
        <time datetime={publishDate.toISOString()}>
          {
            publishDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </time>
        <span aria-hidden="true">·</span>
        <span>{readTime} min read</span>
      </p>
    </div>
  </header>

  <article class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[1fr_300px]">
      <div>
        <AdSlot slot="1111111111" format="horizontal" class="mb-8" />

        <div class="prose max-w-3xl animate-fade-in">
          <slot />
        </div>

        <RelatedArticles articles={relatedArticles} />

        <div
          class="mt-12 flex gap-4 rounded-2xl border border-amber-200/80 bg-gradient-to-r from-amber-50 to-orange-50 p-6 text-sm text-amber-950"
        >
          <span class="text-2xl" aria-hidden="true">⚕️</span>
          <p>
            <strong class="font-semibold">Medical disclaimer:</strong> This article is for general
            information only and does not replace advice from your doctor or qualified health
            professional.
          </p>
        </div>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <AdSlot slot="2222222222" format="vertical" label="Sidebar ad" />
        <div class="overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-sage-100">
          <img
            src={heroImage.src}
            alt={heroImage.alt}
            width="300"
            height="160"
            class="h-32 w-full object-cover"
            loading="lazy"
          />
        </div>
        <ToolSidebar />
      </aside>
    </div>
  </article>
</BaseLayout>
