---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../lib/site';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { category: cat.slug } }));
}

const { category: categorySlug } = Astro.params;
const category = CATEGORIES.find((c) => c.slug === categorySlug);

if (!category) {
  return Astro.redirect('/articles');
}

const articles = (await getCollection('articles'))
  .filter((a) => a.data.category === category.slug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title={`${category.name} Articles`} description={category.description}>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h1 class="mb-3 text-3xl font-bold text-stone-900">{category.name}</h1>
    <p class="mb-10 max-w-2xl text-stone-600">{category.description}</p>
    {
      articles.length === 0 ? (
        <p class="text-muted">Articles coming soon in this category.</p>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
