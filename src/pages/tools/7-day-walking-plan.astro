---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
---

<ToolPageLayout
  title="7-Day Walking Plan Generator"
  description="Build a personalized one-week walking schedule based on your fitness level."
  current="/tools/7-day-walking-plan"
  heroClass="from-sky-600 to-indigo-700"
>
  <p slot="subtitle">A progressive week of walks you can adjust to your schedule. Rest or swap days as needed.</p>

  <div class="tool-panel">
    <div class="tool-panel-header">
      <p class="font-semibold text-white">Choose your level</p>
    </div>
    <div class="p-6">
      <form id="plan-form" class="space-y-5">
        <div>
          <label for="level" class="form-label">Starting fitness</label>
          <select id="level" class="form-input">
            <option value="beginner">Beginner — new or returning to walking</option>
            <option value="intermediate">Intermediate — walk a few times per week</option>
            <option value="active">Active — regular daily movement</option>
          </select>
        </div>
        <div>
          <label for="days" class="form-label">Walk days per week</label>
          <select id="days" class="form-input">
            <option value="5">5 days (with 2 rest days)</option>
            <option value="6">6 days (with 1 rest day)</option>
            <option value="7">7 days (daily)</option>
          </select>
        </div>
        <button type="submit" class="form-submit">Generate my plan</button>
      </form>
      <div id="plan-result" class="mt-6 hidden">
        <ol id="plan-list" class="space-y-3"></ol>
        <p class="mt-6 text-sm text-muted">
          Warm up 2–3 minutes at an easy pace. Stop if you feel pain, dizziness, or chest discomfort.
        </p>
      </div>
    </div>
  </div>

  <script>
    type Level = 'beginner' | 'intermediate' | 'active';
    const PLANS: Record<Level, string[]> = {
      beginner: [
        'Day 1 — 15 min easy walk, flat route',
        'Day 2 — Rest or gentle stretching',
        'Day 3 — 18 min walk, slightly brisk pace',
        'Day 4 — Rest',
        'Day 5 — 20 min walk, add 2 min warm-up',
        'Day 6 — 15 min leisure walk',
        'Day 7 — 22 min walk, celebrate consistency',
      ],
      intermediate: [
        'Day 1 — 25 min brisk walk',
        'Day 2 — 20 min easy recovery walk',
        'Day 3 — 30 min walk with 5 min hills or stairs',
        'Day 4 — Rest or yoga',
        'Day 5 — 28 min brisk walk',
        'Day 6 — 35 min longer walk',
        'Day 7 — 25 min easy walk',
      ],
      active: [
        'Day 1 — 35 min brisk walk',
        'Day 2 — 30 min walk + 10 min strength',
        'Day 3 — 40 min walk with intervals (2 min fast / 3 min easy)',
        'Day 4 — 25 min recovery walk',
        'Day 5 — 45 min walk, varied terrain',
        'Day 6 — 35 min brisk walk',
        'Day 7 — 50 min long walk',
      ],
    };

    const form = document.getElementById('plan-form') as HTMLFormElement;
    const result = document.getElementById('plan-result')!;
    const list = document.getElementById('plan-list')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const level = (document.getElementById('level') as HTMLSelectElement).value as Level;
      const days = Number((document.getElementById('days') as HTMLSelectElement).value);

      let plan = [...PLANS[level]];
      if (days === 5) {
        plan = plan.map((line, i) =>
          i === 1 || i === 3 ? line.replace(/walk.*/i, 'Rest day — light stretching optional') : line,
        );
      } else if (days === 6) {
        plan = plan.map((line, i) => (i === 3 ? line.replace(/Rest.*/i, '20 min easy walk') : line));
      }

      list.innerHTML = plan
        .map(
          (line) =>
            `<li class="rounded-xl border border-sage-200 bg-white px-4 py-3 text-ink-soft"><span class="font-semibold text-sage-900">${line.split(' — ')[0]}</span> — ${line.split(' — ').slice(1).join(' — ')}</li>`,
        )
        .join('');
      result.classList.remove('hidden');
    });
  </script>
</ToolPageLayout>
