---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<BaseLayout
  title="BMI Calculator for Adults 50+"
  description="Free BMI calculator with plain-language results for adults 50 and older."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="mb-3 text-3xl font-bold text-stone-900">BMI Calculator</h1>
    <p class="mb-8 text-stone-600">
      Body Mass Index (BMI) is a screening tool, not a diagnosis. Muscle mass and body composition
      matter — especially as we age. Discuss results with your doctor.
    </p>

    <div class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
      <form id="bmi-form" class="space-y-5">
        <div>
          <label for="unit" class="mb-1 block font-medium">Units</label>
          <select id="unit" class="w-full rounded-lg border border-stone-300 px-4 py-3">
            <option value="imperial">Imperial (lb, ft/in)</option>
            <option value="metric">Metric (kg, cm)</option>
          </select>
        </div>
        <div id="imperial-fields" class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="weight-lb" class="mb-1 block font-medium">Weight (lb)</label>
            <input id="weight-lb" type="number" min="50" max="500" class="w-full rounded-lg border border-stone-300 px-4 py-3" />
          </div>
          <div>
            <label for="height-ft" class="mb-1 block font-medium">Height (ft)</label>
            <input id="height-ft" type="number" min="3" max="8" class="w-full rounded-lg border border-stone-300 px-4 py-3" />
          </div>
          <div>
            <label for="height-in" class="mb-1 block font-medium">Height (in)</label>
            <input id="height-in" type="number" min="0" max="11" class="w-full rounded-lg border border-stone-300 px-4 py-3" />
          </div>
        </div>
        <div id="metric-fields" class="hidden grid gap-4 sm:grid-cols-2">
          <div>
            <label for="weight-kg" class="mb-1 block font-medium">Weight (kg)</label>
            <input id="weight-kg" type="number" min="20" max="250" class="w-full rounded-lg border border-stone-300 px-4 py-3" />
          </div>
          <div>
            <label for="height-cm" class="mb-1 block font-medium">Height (cm)</label>
            <input id="height-cm" type="number" min="100" max="250" class="w-full rounded-lg border border-stone-300 px-4 py-3" />
          </div>
        </div>
        <button type="submit" class="w-full rounded-lg bg-brand-600 py-3 font-semibold text-white hover:bg-brand-700">
          Calculate BMI
        </button>
      </form>
      <div id="bmi-result" class="mt-6 hidden rounded-xl bg-brand-50 p-5 text-center">
        <p class="text-sm text-muted">Your BMI</p>
        <p id="bmi-value" class="text-4xl font-bold text-brand-800"></p>
        <p id="bmi-category" class="mt-2 font-medium text-stone-800"></p>
      </div>
    </div>

    <AdSlot slot="4444444444" class="mt-8" />
  </div>

  <script>
    const form = document.getElementById('bmi-form') as HTMLFormElement;
    const unit = document.getElementById('unit') as HTMLSelectElement;
    const imperial = document.getElementById('imperial-fields')!;
    const metric = document.getElementById('metric-fields')!;
    const result = document.getElementById('bmi-result')!;
    const bmiValue = document.getElementById('bmi-value')!;
    const bmiCategory = document.getElementById('bmi-category')!;

    unit.addEventListener('change', () => {
      const isMetric = unit.value === 'metric';
      imperial.classList.toggle('hidden', isMetric);
      metric.classList.toggle('hidden', !isMetric);
    });

    function categorize(bmi: number): string {
      if (bmi < 18.5) return 'Underweight range — ask your provider if weight gain is appropriate.';
      if (bmi < 25) return 'Normal weight range for most adults.';
      if (bmi < 30) return 'Overweight range — lifestyle changes may help.';
      return 'Obesity range — a clinician can help with a personalized plan.';
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      let bmi = 0;

      if (unit.value === 'imperial') {
        const lb = Number((document.getElementById('weight-lb') as HTMLInputElement).value);
        const ft = Number((document.getElementById('height-ft') as HTMLInputElement).value);
        const inches = Number((document.getElementById('height-in') as HTMLInputElement).value);
        const totalIn = ft * 12 + inches;
        if (!lb || !totalIn) return;
        bmi = (703 * lb) / (totalIn * totalIn);
      } else {
        const kg = Number((document.getElementById('weight-kg') as HTMLInputElement).value);
        const cm = Number((document.getElementById('height-cm') as HTMLInputElement).value);
        if (!kg || !cm) return;
        bmi = kg / (cm / 100) ** 2;
      }

      bmiValue.textContent = bmi.toFixed(1);
      bmiCategory.textContent = categorize(bmi);
      result.classList.remove('hidden');
    });
  </script>
</BaseLayout>
