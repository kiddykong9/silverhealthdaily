---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
---

<ToolPageLayout
  title="Bedtime Calculator"
  description="Find the best bedtime based on your wake-up time and 90-minute sleep cycles."
  current="/tools/bedtime-calculator"
  heroClass="from-indigo-600 to-violet-700"
>
  <p slot="subtitle">Sleep happens in ~90-minute cycles. Working backward from your alarm helps you wake between cycles.</p>

  <div class="tool-panel">
    <div class="tool-panel-header">
      <p class="font-semibold text-white">When do you need to wake up?</p>
    </div>
    <div class="p-6">
      <form id="bedtime-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="wake-hour" class="form-label">Hour (24h or use AM/PM below)</label>
            <input id="wake-hour" type="number" min="1" max="12" value="7" class="form-input" />
          </div>
          <div>
            <label for="wake-minute" class="form-label">Minute</label>
            <input id="wake-minute" type="number" min="0" max="59" value="0" class="form-input" />
          </div>
        </div>
        <div>
          <label for="wake-ampm" class="form-label">AM / PM</label>
          <select id="wake-ampm" class="form-input">
            <option value="AM">AM</option>
            <option value="PM">PM</option>
          </select>
        </div>
        <div>
          <label for="fall-asleep" class="form-label">Minutes to fall asleep</label>
          <input id="fall-asleep" type="number" min="5" max="45" value="15" class="form-input" />
        </div>
        <button type="submit" class="form-submit">Calculate bedtimes</button>
      </form>
      <div id="bedtime-result" class="result-box mt-6 hidden">
        <p class="text-sm font-medium text-muted">Suggested bedtimes (5–6 cycles)</p>
        <ul id="bedtime-list" class="mt-3 space-y-2 font-display text-lg font-semibold text-sage-800"></ul>
        <p class="mt-4 text-sm text-muted">
          Pick the time that gives you enough sleep. Most adults need 7–9 hours.
        </p>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('bedtime-form') as HTMLFormElement;
    const result = document.getElementById('bedtime-result')!;
    const list = document.getElementById('bedtime-list')!;

    function to24(h: number, ampm: string): number {
      if (ampm === 'AM') return h === 12 ? 0 : h;
      return h === 12 ? 12 : h + 12;
    }

    function formatTime(date: Date): string {
      return date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const h = Number((document.getElementById('wake-hour') as HTMLInputElement).value);
      const m = Number((document.getElementById('wake-minute') as HTMLInputElement).value);
      const ampm = (document.getElementById('wake-ampm') as HTMLSelectElement).value;
      const fallAsleep = Number((document.getElementById('fall-asleep') as HTMLInputElement).value);

      const wake = new Date();
      wake.setHours(to24(h, ampm), m, 0, 0);

      const cycleMin = 90;
      const options: string[] = [];
      for (let cycles = 6; cycles >= 4; cycles--) {
        const total = cycles * cycleMin + fallAsleep;
        const bed = new Date(wake.getTime() - total * 60000);
        const hours = (cycles * cycleMin) / 60;
        options.push(`${formatTime(bed)} — ~${hours}h sleep (${cycles} cycles)`);
      }

      list.innerHTML = options.map((o) => `<li class="rounded-lg bg-sage-50 px-4 py-2">${o}</li>`).join('');
      result.classList.remove('hidden');
    });
  </script>
</ToolPageLayout>
