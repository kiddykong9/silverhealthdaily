---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
---

<ToolPageLayout
  title="Water Intake Calculator"
  description="Estimate how much water to drink daily based on weight and activity level."
  current="/tools/water-intake-calculator"
  heroClass="from-sky-600 to-blue-700"
>
  <p slot="subtitle">It's easy to under-drink when you're busy — steady hydration through the day matters.</p>

  <div class="tool-panel">
    <div class="tool-panel-header">
      <p class="font-semibold text-white">Your details</p>
    </div>
    <div class="p-6">
      <form id="water-form" class="space-y-5">
        <div>
          <label for="weight" class="form-label">Weight (lb)</label>
          <input id="weight" type="number" min="80" max="400" required class="form-input" />
        </div>
        <div>
          <label for="activity" class="form-label">Activity level</label>
          <select id="activity" class="form-input">
            <option value="1">Mostly sedentary</option>
            <option value="1.15">Light activity (walking most days)</option>
            <option value="1.3">Moderate activity (30+ min daily)</option>
            <option value="1.45">Very active</option>
          </select>
        </div>
        <button type="submit" class="form-submit">Calculate intake</button>
      </form>
      <div id="water-result" class="result-box hidden">
        <p class="text-sm font-medium text-muted">Suggested daily intake</p>
        <p id="water-oz" class="font-display text-5xl font-bold text-sage-800"></p>
        <p id="water-liters" class="mt-2 text-ink-soft"></p>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('water-form') as HTMLFormElement;
    const result = document.getElementById('water-result')!;
    const ozEl = document.getElementById('water-oz')!;
    const litersEl = document.getElementById('water-liters')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const weight = Number((document.getElementById('weight') as HTMLInputElement).value);
      const activity = Number((document.getElementById('activity') as HTMLSelectElement).value);
      const baseOz = weight * 0.5;
      const totalOz = Math.round(baseOz * activity);
      const liters = (totalOz * 0.0295735).toFixed(1);
      ozEl.textContent = `${totalOz} fl oz`;
      litersEl.textContent = `≈ ${liters} liters (includes fluids from food over the day)`;
      result.classList.remove('hidden');
    });
  </script>
</ToolPageLayout>
