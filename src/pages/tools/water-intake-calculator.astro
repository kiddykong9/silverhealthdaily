---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<BaseLayout
  title="Daily Water Intake Calculator"
  description="Estimate how much water to drink daily based on weight and activity level."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="mb-3 text-3xl font-bold text-stone-900">Water Intake Calculator</h1>
    <p class="mb-8 text-stone-600">
      Hydration needs increase with activity and hot weather. Older adults often feel thirst less
      strongly — aim for steady intake through the day.
    </p>

    <div class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
      <form id="water-form" class="space-y-5">
        <div>
          <label for="weight" class="mb-1 block font-medium">Weight (lb)</label>
          <input id="weight" type="number" min="80" max="400" required class="w-full rounded-lg border border-stone-300 px-4 py-3" />
        </div>
        <div>
          <label for="activity" class="mb-1 block font-medium">Activity level</label>
          <select id="activity" class="w-full rounded-lg border border-stone-300 px-4 py-3">
            <option value="1">Mostly sedentary</option>
            <option value="1.15">Light activity (walking most days)</option>
            <option value="1.3">Moderate activity (30+ min daily)</option>
            <option value="1.45">Very active</option>
          </select>
        </div>
        <button type="submit" class="w-full rounded-lg bg-brand-600 py-3 font-semibold text-white hover:bg-brand-700">
          Calculate intake
        </button>
      </form>
      <div id="water-result" class="mt-6 hidden rounded-xl bg-brand-50 p-5 text-center">
        <p class="text-sm text-muted">Suggested daily intake</p>
        <p id="water-oz" class="text-4xl font-bold text-brand-800"></p>
        <p id="water-liters" class="mt-2 text-stone-700"></p>
      </div>
    </div>

    <AdSlot slot="5555555555" class="mt-8" />
  </div>

  <script>
    const form = document.getElementById('water-form') as HTMLFormElement;
    const result = document.getElementById('water-result')!;
    const ozEl = document.getElementById('water-oz')!;
    const litersEl = document.getElementById('water-liters')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const weight = Number((document.getElementById('weight') as HTMLInputElement).value);
      const activity = Number((document.getElementById('activity') as HTMLSelectElement).value);
      const baseOz = weight * 0.5;
      const totalOz = Math.round(baseOz * activity);
      const liters = (totalOz * 0.0295735).toFixed(1);
      ozEl.textContent = `${totalOz} fl oz`;
      litersEl.textContent = `≈ ${liters} liters (includes fluids from food over the day)`;
      result.classList.remove('hidden');
    });
  </script>
</BaseLayout>
