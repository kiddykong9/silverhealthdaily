---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<BaseLayout
  title="Walking Calorie Calculator"
  description="Estimate calories burned from walking based on weight, pace, and duration."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="mb-3 text-3xl font-bold text-stone-900">Walking Calorie Calculator</h1>
    <p class="mb-8 text-stone-600">
      Walking is one of the safest exercises for adults 50+. This estimate uses MET values for
      common walking speeds.
    </p>

    <div class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
      <form id="walk-form" class="space-y-5">
        <div>
          <label for="w-weight" class="mb-1 block font-medium">Weight (lb)</label>
          <input id="w-weight" type="number" min="80" max="400" required class="w-full rounded-lg border border-stone-300 px-4 py-3" />
        </div>
        <div>
          <label for="pace" class="mb-1 block font-medium">Walking pace</label>
          <select id="pace" class="w-full rounded-lg border border-stone-300 px-4 py-3">
            <option value="2.0">Slow (2 mph)</option>
            <option value="3.0">Moderate (3 mph)</option>
            <option value="3.5">Brisk (3.5 mph)</option>
            <option value="4.0">Very brisk (4 mph)</option>
          </select>
        </div>
        <div>
          <label for="minutes" class="mb-1 block font-medium">Duration (minutes)</label>
          <input id="minutes" type="number" min="5" max="180" required class="w-full rounded-lg border border-stone-300 px-4 py-3" />
        </div>
        <button type="submit" class="w-full rounded-lg bg-brand-600 py-3 font-semibold text-white hover:bg-brand-700">
          Calculate calories
        </button>
      </form>
      <div id="walk-result" class="mt-6 hidden rounded-xl bg-brand-50 p-5 text-center">
        <p class="text-sm text-muted">Estimated calories burned</p>
        <p id="calories" class="text-4xl font-bold text-brand-800"></p>
        <p id="distance" class="mt-2 text-stone-700"></p>
      </div>
    </div>

    <AdSlot slot="6666666666" class="mt-8" />
  </div>

  <script>
    const metMap: Record<string, number> = {
      '2.0': 2.8,
      '3.0': 3.5,
      '3.5': 4.3,
      '4.0': 5.0,
    };

    const form = document.getElementById('walk-form') as HTMLFormElement;
    const result = document.getElementById('walk-result')!;
    const caloriesEl = document.getElementById('calories')!;
    const distanceEl = document.getElementById('distance')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const weightLb = Number((document.getElementById('w-weight') as HTMLInputElement).value);
      const pace = (document.getElementById('pace') as HTMLSelectElement).value;
      const minutes = Number((document.getElementById('minutes') as HTMLInputElement).value);
      const weightKg = weightLb * 0.453592;
      const met = metMap[pace];
      const hours = minutes / 60;
      const calories = Math.round(met * weightKg * hours);
      const miles = (Number(pace) * hours).toFixed(2);
      caloriesEl.textContent = `${calories} kcal`;
      distanceEl.textContent = `Approx. ${miles} miles at ${pace} mph`;
      result.classList.remove('hidden');
    });
  </script>
</BaseLayout>
