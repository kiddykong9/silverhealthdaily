---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
---

<ToolPageLayout
  title="Calories Burned Walking Calculator"
  description="Free calories burned walking calculator — enter weight, pace, and minutes for an instant estimate. Brisk walk, 30 minutes, or daily steps."
  current="/tools/walking-calorie-calculator"
  heroClass="from-amber-500 to-orange-600"
>
  <span slot="hero" class="text-4xl">🚶</span>
  <p slot="subtitle">How many calories does walking burn? Enter weight, pace, and duration — get an estimate in seconds.</p>

  <div class="tool-panel">
    <div class="tool-panel-header">
      <p class="font-semibold text-white">Your walk</p>
    </div>
    <div class="p-6">
      <form id="walk-form" class="space-y-5">
        <div>
          <label for="w-weight" class="form-label">Weight (lb)</label>
          <input id="w-weight" type="number" min="80" max="400" required class="form-input" />
        </div>
        <div>
          <label for="pace" class="form-label">Walking pace</label>
          <select id="pace" class="form-input">
            <option value="2.0">Slow (2 mph)</option>
            <option value="3.0">Moderate (3 mph)</option>
            <option value="3.5">Brisk (3.5 mph)</option>
            <option value="4.0">Very brisk (4 mph)</option>
          </select>
        </div>
        <div>
          <label for="minutes" class="form-label">Duration (minutes)</label>
          <input id="minutes" type="number" min="5" max="180" required class="form-input" />
        </div>
        <button type="submit" class="form-submit">Calculate calories</button>
      </form>
      <div id="walk-result" class="result-box hidden">
        <p class="text-sm font-medium text-muted">Estimated calories burned</p>
        <p id="calories" class="font-display text-5xl font-bold text-sage-800"></p>
        <p id="distance" class="mt-2 text-ink-soft"></p>
      </div>
    </div>
  </div>

  <script>
    const metMap: Record<string, number> = {
      '2.0': 2.8,
      '3.0': 3.5,
      '3.5': 4.3,
      '4.0': 5.0,
    };

    const form = document.getElementById('walk-form') as HTMLFormElement;
    const result = document.getElementById('walk-result')!;
    const caloriesEl = document.getElementById('calories')!;
    const distanceEl = document.getElementById('distance')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const weightLb = Number((document.getElementById('w-weight') as HTMLInputElement).value);
      const pace = (document.getElementById('pace') as HTMLSelectElement).value;
      const minutes = Number((document.getElementById('minutes') as HTMLInputElement).value);
      const weightKg = weightLb * 0.453592;
      const met = metMap[pace];
      const hours = minutes / 60;
      const calories = Math.round(met * weightKg * hours);
      const miles = (Number(pace) * hours).toFixed(2);
      caloriesEl.textContent = `${calories} kcal`;
      distanceEl.textContent = `Approx. ${miles} miles at ${pace} mph`;
      result.classList.remove('hidden');
    });
  </script>
</ToolPageLayout>
