---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import ToolSidebar from '../../components/ToolSidebar.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import { NUTRITION_LABEL_ROWS } from '../../lib/nutrition';
---

<BaseLayout
  title="Food Nutrition Calculator"
  description="Search 300,000+ USDA foods, scan barcodes, and log daily meals with full nutrition facts — free, no signup."
>
  <section class="bg-gradient-to-br from-emerald-600 to-green-700 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">Food Nutrition Calculator</h1>
      <p class="mt-2 text-white/85">
        Search by name, scan a barcode, and build a daily food log — calories, protein, fat, carbs, sugar, and more.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[1fr_280px]">
      <div class="space-y-6">
        <!-- Barcode -->
        <div class="tool-panel">
          <div class="tool-panel-header">
            <p class="font-semibold text-white">Scan or enter barcode</p>
          </div>
          <div class="p-6">
            <div class="flex flex-col gap-3 sm:flex-row">
              <input
                id="barcode-input"
                type="text"
                inputmode="numeric"
                placeholder="UPC / EAN numbers under the barcode"
                class="form-input flex-1"
                autocomplete="off"
              />
              <button type="button" id="barcode-btn" class="form-submit shrink-0 sm:!w-auto">Look up</button>
              <button
                type="button"
                id="scan-btn"
                class="rounded-xl border border-sage-300 bg-white px-5 py-2.5 text-sm font-semibold text-sage-800 transition hover:bg-sage-50"
              >
                Scan with camera
              </button>
            </div>
            <p id="barcode-status" class="mt-2 text-sm text-muted" aria-live="polite"></p>
          </div>
        </div>

        <!-- Search -->
        <div class="tool-panel">
          <div class="tool-panel-header">
            <p class="font-semibold text-white">Or search by name</p>
          </div>
          <div class="p-6">
            <div class="flex flex-col gap-4 sm:flex-row">
              <input
                id="search-input"
                type="search"
                placeholder="e.g. banana, chicken breast, Cheerios…"
                class="form-input flex-1"
                autocomplete="off"
              />
              <button type="button" id="search-btn" class="form-submit shrink-0 sm:!w-auto">Search</button>
            </div>
            <label class="mt-3 flex items-center gap-2 text-sm text-ink-soft">
              <input id="include-branded" type="checkbox" checked class="rounded border-sage-300 text-sage-700" />
              Include branded & packaged products
            </label>
            <p id="search-status" class="mt-3 text-sm text-muted" aria-live="polite"></p>
            <ul id="search-results" class="mt-4 max-h-80 space-y-2 overflow-y-auto"></ul>
          </div>
        </div>

        <!-- Selected food -->
        <div id="detail-panel" class="tool-panel hidden">
          <div class="tool-panel-header">
            <p id="detail-title" class="font-semibold text-white"></p>
          </div>
          <div class="p-6">
            <p id="detail-meta" class="text-sm text-muted"></p>
            <div class="mt-4 flex flex-wrap items-end gap-4">
              <div>
                <label for="meal-type" class="form-label">Meal</label>
                <select id="meal-type" class="form-input !w-36">
                  <option value="breakfast">Breakfast</option>
                  <option value="lunch">Lunch</option>
                  <option value="dinner">Dinner</option>
                  <option value="snack">Snack</option>
                </select>
              </div>
              <div>
                <label for="servings" class="form-label">Servings</label>
                <input id="servings" type="number" min="0.25" max="20" step="0.25" value="1" class="form-input !w-28" />
              </div>
              <button type="button" id="add-btn" class="form-submit !w-auto !px-6 !py-2.5 !text-sm">Add to log</button>
            </div>
            <div class="nutrition-label mt-6 max-w-sm">
              <p class="text-lg font-bold text-ink">Nutrition Facts</p>
              <p id="label-serving" class="border-b-4 border-ink pb-1 text-sm text-muted"></p>
              <div class="border-b border-ink py-1">
                <p class="text-sm font-bold">Amount per serving</p>
                <p class="flex items-end gap-2">
                  <span class="text-3xl font-black leading-none">Calories</span>
                  <span id="label-calories" class="ml-auto text-3xl font-black leading-none">—</span>
                </p>
              </div>
              <p class="border-b border-ink py-0.5 text-right text-xs font-bold">% Daily Value*</p>
              <div id="label-rows"></div>
              <p class="mt-2 text-[10px] leading-tight text-muted">
                * Percent Daily Values based on a 2,000 calorie diet. Data from USDA FoodData Central.
              </p>
            </div>
          </div>
        </div>

        <!-- Food log -->
        <div class="tool-panel">
          <div class="tool-panel-header flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="font-semibold text-white">Your food log</p>
              <p id="log-date" class="text-xs text-white/75"></p>
            </div>
            <button type="button" id="clear-log" class="text-sm text-white/80 underline hover:text-white">Clear today</button>
          </div>
          <div class="p-6">
            <p class="mb-3 text-xs text-muted">
              Saved on this device only — no account needed. Clearing browser data will reset your log.
            </p>
            <ul id="log-list" class="space-y-2 text-sm">
              <li id="log-empty" class="rounded-lg bg-sage-50 px-4 py-6 text-center text-muted">
                Search or scan a food above, then add it here.
              </li>
            </ul>
            <div id="log-totals" class="nutrition-label mt-6 hidden max-w-sm">
              <p class="text-lg font-bold text-ink">Today's totals</p>
              <div class="border-b-4 border-ink pb-1">
                <p class="flex items-end gap-2">
                  <span class="text-2xl font-black">Calories</span>
                  <span id="total-calories" class="ml-auto text-2xl font-black">0</span>
                </p>
              </div>
              <div id="total-rows"></div>
            </div>
          </div>
        </div>

        <RelatedTools current="/tools/food-calorie-calculator" />

        <p class="text-sm text-muted">
          New to tracking?
          <a href="/articles/how-to-track-calories-and-nutrition-free" class="font-semibold text-sage-700 hover:text-sage-900">
            Read our free guide →
          </a>
        </p>

        <AdSlot slot="4444444444" />
      </div>

      <aside class="lg:sticky lg:top-24 lg:self-start">
        <ToolSidebar current="/tools/food-calorie-calculator" />
      </aside>
    </div>
  </div>

  <!-- Barcode scanner modal -->
  <div id="scan-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4" role="dialog" aria-modal="true" aria-label="Barcode scanner">
    <div class="w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-sage-100 px-4 py-3">
        <p class="font-semibold text-ink">Scan barcode</p>
        <button type="button" id="scan-close" class="text-muted hover:text-ink" aria-label="Close">✕</button>
      </div>
      <div class="relative aspect-[4/3] bg-black">
        <video id="scan-video" class="h-full w-full object-cover" playsinline muted></video>
        <p id="scan-hint" class="absolute bottom-3 left-0 right-0 text-center text-sm text-white drop-shadow">Point camera at the barcode</p>
      </div>
      <p id="scan-error" class="px-4 py-3 text-sm text-red-700"></p>
    </div>
  </div>

  <style>
    .nutrition-label {
      border: 2px solid #1a1a1a;
      padding: 0.75rem;
      font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .label-row {
      display: flex;
      justify-content: space-between;
      border-bottom: 1px solid #ccc;
      padding: 0.2rem 0;
      font-size: 0.875rem;
    }
    .label-row.indent { padding-left: 1rem; }
    .label-row.bold { font-weight: 700; }
    #scan-modal.open { display: flex; }
  </style>

  <script define:vars={{ labelRows: NUTRITION_LABEL_ROWS }}>
    const STORAGE_KEY = 'shd-food-log';
    const MEAL_LABELS = { breakfast: 'Breakfast', lunch: 'Lunch', dinner: 'Dinner', snack: 'Snack' };

    let selected = null;
    let log = [];
    let scanStream = null;
    let scanInterval = null;

    const els = {
      searchInput: document.getElementById('search-input'),
      searchBtn: document.getElementById('search-btn'),
      searchStatus: document.getElementById('search-status'),
      searchResults: document.getElementById('search-results'),
      includeBranded: document.getElementById('include-branded'),
      barcodeInput: document.getElementById('barcode-input'),
      barcodeBtn: document.getElementById('barcode-btn'),
      barcodeStatus: document.getElementById('barcode-status'),
      scanBtn: document.getElementById('scan-btn'),
      scanModal: document.getElementById('scan-modal'),
      scanVideo: document.getElementById('scan-video'),
      scanClose: document.getElementById('scan-close'),
      scanError: document.getElementById('scan-error'),
      detailPanel: document.getElementById('detail-panel'),
      detailTitle: document.getElementById('detail-title'),
      detailMeta: document.getElementById('detail-meta'),
      mealType: document.getElementById('meal-type'),
      servingsEl: document.getElementById('servings'),
      addBtn: document.getElementById('add-btn'),
      labelServing: document.getElementById('label-serving'),
      labelCalories: document.getElementById('label-calories'),
      labelRowsEl: document.getElementById('label-rows'),
      logList: document.getElementById('log-list'),
      logEmpty: document.getElementById('log-empty'),
      logTotals: document.getElementById('log-totals'),
      logDate: document.getElementById('log-date'),
      totalCalories: document.getElementById('total-calories'),
      totalRowsEl: document.getElementById('total-rows'),
    };

    const DV = {
      totalFat: 78, saturatedFat: 20, cholesterol: 300, sodium: 2300,
      totalCarbs: 275, fiber: 28, addedSugars: 50, protein: 50,
      vitaminD: 20, calcium: 1300, iron: 18, potassium: 4700,
    };

    function dateKey(d = new Date()) {
      return d.toISOString().slice(0, 10);
    }

    function loadLog() {
      try {
        const all = JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '{}');
        const cutoff = new Date();
        cutoff.setDate(cutoff.getDate() - 30);
        for (const k of Object.keys(all)) {
          if (k < dateKey(cutoff)) delete all[k];
        }
        localStorage.setItem(STORAGE_KEY, JSON.stringify(all));
        return all[dateKey()] ?? [];
      } catch {
        return [];
      }
    }

    function saveLog() {
      try {
        const all = JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '{}');
        all[dateKey()] = log;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(all));
      } catch { /* storage full or private mode */ }
    }

    function guessMeal() {
      const h = new Date().getHours();
      if (h < 11) return 'breakfast';
      if (h < 15) return 'lunch';
      if (h < 21) return 'dinner';
      return 'snack';
    }

    function formatVal(key, val) {
      if (val == null) return '—';
      if (key === 'calories') return String(Math.round(val));
      if (val < 0.01 && val > 0) return '<0.01';
      return String(val);
    }

    function servingText(food, mult = 1) {
      const base = food.householdServing || (food.servingSize && food.servingSizeUnit
        ? `${food.servingSize} ${food.servingSizeUnit}` : '1 serving');
      return mult === 1 ? base : `${mult} × ${base}`;
    }

    function scaleNutrition(nutrition, mult) {
      const out = {};
      for (const [k, v] of Object.entries(nutrition)) {
        out[k] = v != null ? Math.round(v * mult * 100) / 100 : null;
      }
      return out;
    }

    async function parseJsonResponse(res) {
      const text = await res.text();
      try {
        return JSON.parse(text);
      } catch {
        throw new Error('Server returned an invalid response. Try again shortly.');
      }
    }

    function renderLabelRows(container, nutrition, showDv = true) {
      container.innerHTML = labelRows
        .filter((r) => r.key !== 'calories')
        .map((row) => {
          const val = nutrition[row.key];
          if (val == null && row.key !== 'transFat') return '';
          const dv = DV[row.key];
          const pct = dv && val != null ? Math.round((val / dv) * 100) : null;
          return `<div class="label-row${row.indent ? ' indent' : ''}${row.bold ? ' bold' : ''}">
            <span>${row.label} ${val != null ? formatVal(row.key, val) + row.unit : ''}</span>
            ${showDv && pct != null ? `<span>${pct}%</span>` : '<span></span>'}
          </div>`;
        })
        .join('');
    }

    function renderDetail() {
      if (!selected) return;
      const mult = Number(els.servingsEl.value) || 1;
      const n = scaleNutrition(selected.nutrition, mult);
      els.detailTitle.textContent = selected.description;
      els.detailMeta.textContent = [selected.brandOwner, selected.dataType, selected.gtinUpc ? `UPC ${selected.gtinUpc}` : '', selected.fdcId ? `FDC #${selected.fdcId}` : ''].filter(Boolean).join(' · ');
      els.labelServing.textContent = `Serving size ${servingText(selected, mult)}`;
      els.labelCalories.textContent = formatVal('calories', n.calories);
      renderLabelRows(els.labelRowsEl, n);
    }

    function renderResults(foods, statusEl, onSelect) {
      statusEl.textContent = foods.length ? `Found ${foods.length} match${foods.length > 1 ? 'es' : ''}` : 'No results';
      els.searchResults.innerHTML = foods.map((food) => {
        const cal = food.nutrition?.calories;
        const sub = [food.brandOwner, food.dataType].filter(Boolean).join(' · ');
        return `<li><button type="button" data-fdc="${food.fdcId}" class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-left transition hover:border-sage-400 hover:bg-sage-50">
          <span class="block font-medium text-ink">${food.description}</span>
          <span class="block text-xs text-muted">${sub}${cal != null ? ` · ${Math.round(cal)} cal/serving` : ''}</span>
        </button></li>`;
      }).join('');
      els.searchResults.querySelectorAll('[data-fdc]').forEach((btn) => {
        btn.addEventListener('click', () => onSelect(Number(btn.dataset.fdc), foods));
      });
    }

    async function selectFood(fdcId, cachedFoods) {
      els.detailPanel.classList.remove('hidden');
      els.detailTitle.textContent = 'Loading…';
      els.servingsEl.value = '1';
      els.mealType.value = guessMeal();

      const cached = cachedFoods?.find((f) => f.fdcId === fdcId);
      if (cached) {
        selected = cached;
        renderDetail();
        return;
      }

      try {
        const res = await fetch(`/api/food/${fdcId}`);
        const data = await parseJsonResponse(res);
        if (!res.ok) throw new Error(data.error || 'Failed to load food');
        selected = data;
        renderDetail();
      } catch (err) {
        els.detailMeta.textContent = err.message;
      }
    }

    async function runSearch() {
      const q = els.searchInput.value.trim();
      if (q.length < 2) {
        els.searchStatus.textContent = 'Enter at least 2 characters.';
        return;
      }
      els.searchStatus.textContent = 'Searching…';
      els.searchResults.innerHTML = '';
      els.searchBtn.disabled = true;
      try {
        const branded = els.includeBranded.checked ? '1' : '0';
        const res = await fetch(`/api/food-search?q=${encodeURIComponent(q)}&branded=${branded}`);
        const data = await parseJsonResponse(res);
        if (!res.ok) throw new Error(data.error || 'Search failed');
        els.searchStatus.textContent = `${data.totalHits.toLocaleString()} results — showing ${data.foods.length}`;
        renderResults(data.foods, els.searchStatus, selectFood);
      } catch (err) {
        els.searchStatus.textContent = err.message;
      } finally {
        els.searchBtn.disabled = false;
      }
    }

    async function runBarcodeLookup(code) {
      const upc = String(code ?? els.barcodeInput.value).trim();
      if (!upc) {
        els.barcodeStatus.textContent = 'Enter a barcode number.';
        return;
      }
      els.barcodeStatus.textContent = 'Looking up barcode…';
      els.barcodeBtn.disabled = true;
      try {
        const res = await fetch(`/api/food-barcode?upc=${encodeURIComponent(upc)}`);
        const data = await parseJsonResponse(res);
        if (!res.ok) throw new Error(data.error || 'Barcode not found');
        els.barcodeStatus.textContent = `Found: ${data.foods[0].description}`;
        els.barcodeInput.value = data.gtinUpc ?? upc;
        if (data.foods.length === 1) {
          await selectFood(data.foods[0].fdcId, data.foods);
        } else {
          renderResults(data.foods, els.barcodeStatus, selectFood);
        }
      } catch (err) {
        els.barcodeStatus.textContent = err.message;
      } finally {
        els.barcodeBtn.disabled = false;
      }
    }

    function renderLog() {
      els.logDate.textContent = new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });

      if (log.length === 0) {
        els.logEmpty.classList.remove('hidden');
        els.logTotals.classList.add('hidden');
        els.logList.querySelectorAll('[data-entry]').forEach((el) => el.remove());
        return;
      }

      els.logEmpty.classList.add('hidden');
      els.logTotals.classList.remove('hidden');
      els.logList.querySelectorAll('[data-entry]').forEach((el) => el.remove());

      const allNutrition = [];
      log.forEach((entry) => {
        const n = scaleNutrition(entry.food.nutrition, entry.servings);
        allNutrition.push(n);
        const li = document.createElement('li');
        li.dataset.entry = entry.uid;
        li.className = 'flex items-center justify-between gap-3 rounded-lg border border-sage-100 bg-white px-4 py-3';
        li.innerHTML = `<span>
          <span class="text-xs font-semibold uppercase text-sage-600">${MEAL_LABELS[entry.meal] ?? entry.meal}</span>
          <span class="block font-medium text-ink">${entry.food.description}</span>
          <span class="block text-muted">${servingText(entry.food, entry.servings)}</span>
        </span>
        <span class="flex items-center gap-3 shrink-0">
          <span class="font-semibold text-sage-800">${formatVal('calories', n.calories)} cal</span>
          <button type="button" data-remove="${entry.uid}" class="text-muted hover:text-red-600" aria-label="Remove">✕</button>
        </span>`;
        els.logList.appendChild(li);
      });

      const totals = {};
      for (const n of allNutrition) {
        for (const [k, v] of Object.entries(n)) {
          if (v != null) totals[k] = Math.round(((totals[k] ?? 0) + v) * 100) / 100;
        }
      }
      els.totalCalories.textContent = formatVal('calories', totals.calories);
      renderLabelRows(els.totalRowsEl, totals, false);
      saveLog();
    }

    async function openScanner() {
      els.scanError.textContent = '';
      if (!('BarcodeDetector' in window)) {
        els.scanError.textContent = 'Camera scan needs Chrome or Edge. Enter the barcode numbers manually instead.';
        els.scanModal.classList.add('open');
        return;
      }
      try {
        scanStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
        els.scanVideo.srcObject = scanStream;
        await els.scanVideo.play();
        els.scanModal.classList.add('open');

        const detector = new BarcodeDetector({ formats: ['ean_13', 'ean_8', 'upc_a', 'upc_e', 'code_128'] });
        scanInterval = setInterval(async () => {
          try {
            const codes = await detector.detect(els.scanVideo);
            if (codes.length > 0) {
              closeScanner();
              els.barcodeInput.value = codes[0].rawValue;
              runBarcodeLookup(codes[0].rawValue);
            }
          } catch { /* frame skip */ }
        }, 350);
      } catch {
        els.scanError.textContent = 'Camera access denied. Enter the barcode manually.';
        els.scanModal.classList.add('open');
      }
    }

    function closeScanner() {
      els.scanModal.classList.remove('open');
      if (scanInterval) { clearInterval(scanInterval); scanInterval = null; }
      if (scanStream) {
        scanStream.getTracks().forEach((t) => t.stop());
        scanStream = null;
      }
    }

    els.searchBtn.addEventListener('click', runSearch);
    els.searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runSearch(); });
    let debounce;
    els.searchInput.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(runSearch, 450);
    });

    els.barcodeBtn.addEventListener('click', () => runBarcodeLookup());
    els.barcodeInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runBarcodeLookup(); });
    els.scanBtn.addEventListener('click', openScanner);
    els.scanClose.addEventListener('click', closeScanner);

    els.servingsEl.addEventListener('input', renderDetail);
    els.addBtn.addEventListener('click', () => {
      if (!selected) return;
      log.push({
        uid: `${Date.now()}-${Math.random().toString(36).slice(2)}`,
        food: selected,
        servings: Number(els.servingsEl.value) || 1,
        meal: els.mealType.value,
      });
      renderLog();
    });

    els.logList.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-remove]');
      if (!btn) return;
      log = log.filter((x) => x.uid !== btn.dataset.remove);
      renderLog();
    });

    document.getElementById('clear-log').addEventListener('click', () => {
      log = [];
      renderLog();
    });

    log = loadLog();
    els.mealType.value = guessMeal();
    renderLog();
  </script>
</BaseLayout>
