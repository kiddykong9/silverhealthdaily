---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
---

<ToolPageLayout
  title="Daily Step Goal Calculator"
  description="Get a personalized daily step target based on your current activity and goals."
  current="/tools/step-goal-calculator"
  heroClass="from-sky-600 to-blue-700"
>
  <p slot="subtitle">10,000 steps is a popular target — but the right number depends on where you are today.</p>

  <div class="tool-panel">
    <div class="tool-panel-header">
      <p class="font-semibold text-white">Your starting point</p>
    </div>
    <div class="p-6">
      <form id="steps-form" class="space-y-5">
        <div>
          <label for="current" class="form-label">Average steps per day now (estimate)</label>
          <input id="current" type="number" min="500" max="25000" value="4000" class="form-input" />
        </div>
        <div>
          <label for="goal-type" class="form-label">Goal</label>
          <select id="goal-type" class="form-input">
            <option value="maintain">Maintain current fitness</option>
            <option value="improve">Gradually improve (+15%)</option>
            <option value="active">Reach active lifestyle (8,000+)</option>
            <option value="challenge">Challenge target (10,000)</option>
          </select>
        </div>
        <button type="submit" class="form-submit">Calculate step goal</button>
      </form>
      <div id="steps-result" class="result-box mt-6 hidden">
        <p class="text-sm font-medium text-muted">Your daily step goal</p>
        <p id="steps-value" class="font-display text-5xl font-bold text-sage-800"></p>
        <p id="steps-tip" class="mt-2 text-ink-soft"></p>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('steps-form') as HTMLFormElement;
    const result = document.getElementById('steps-result')!;
    const valueEl = document.getElementById('steps-value')!;
    const tipEl = document.getElementById('steps-tip')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const current = Number((document.getElementById('current') as HTMLInputElement).value);
      const goalType = (document.getElementById('goal-type') as HTMLSelectElement).value;
      if (!current) return;

      let target = current;
      if (goalType === 'maintain') target = current;
      else if (goalType === 'improve') target = Math.round(current * 1.15);
      else if (goalType === 'active') target = Math.max(8000, Math.round(current * 1.2));
      else target = 10000;

      target = Math.min(15000, Math.max(3000, Math.round(target / 250) * 250));

      valueEl.textContent = target.toLocaleString();
      const extra = target - current;
      tipEl.textContent =
        extra > 0
          ? `Add about ${extra.toLocaleString()} steps — try a 10-minute walk after lunch.`
          : 'You are already at a strong level. Focus on consistency.';
      result.classList.remove('hidden');
    });
  </script>
</ToolPageLayout>
