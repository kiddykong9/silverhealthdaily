---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
---

<ToolPageLayout
  title="Target Heart Rate Calculator"
  description="Calculate moderate and vigorous heart rate zones for walking and cardio exercise."
  current="/tools/target-heart-rate-calculator"
  heroClass="from-rose-600 to-red-700"
>
  <p slot="subtitle">Know your target zones before brisk walking or cardio. Always start slow if you are new to exercise.</p>

  <div class="tool-panel">
    <div class="tool-panel-header">
      <p class="font-semibold text-white">Enter your age</p>
    </div>
    <div class="p-6">
      <form id="hr-form" class="space-y-5">
        <div>
          <label for="age" class="form-label">Age (years)</label>
          <input id="age" type="number" min="18" max="100" class="form-input" placeholder="e.g. 55" />
        </div>
        <div>
          <label for="resting" class="form-label">Resting heart rate (optional, bpm)</label>
          <input id="resting" type="number" min="40" max="120" class="form-input" placeholder="e.g. 68" />
        </div>
        <button type="submit" class="form-submit">Calculate zones</button>
      </form>
      <div id="hr-result" class="result-box mt-6 hidden space-y-4">
        <div>
          <p class="text-sm font-medium text-muted">Moderate intensity (50–70% max HR)</p>
          <p id="hr-moderate" class="font-display text-2xl font-bold text-sage-800"></p>
        </div>
        <div>
          <p class="text-sm font-medium text-muted">Vigorous intensity (70–85% max HR)</p>
          <p id="hr-vigorous" class="font-display text-2xl font-bold text-sage-800"></p>
        </div>
        <p class="text-sm text-muted">
          For walking, aim for moderate zone — you can talk but not sing. Check with your doctor before intense exercise.
        </p>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('hr-form') as HTMLFormElement;
    const result = document.getElementById('hr-result')!;
    const modEl = document.getElementById('hr-moderate')!;
    const vigEl = document.getElementById('hr-vigorous')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const age = Number((document.getElementById('age') as HTMLInputElement).value);
      const resting = Number((document.getElementById('resting') as HTMLInputElement).value);
      if (!age) return;

      let maxHr = 220 - age;
      if (resting > 0) {
        maxHr = 208 - 0.7 * age;
      }

      const modLow = Math.round(maxHr * 0.5);
      const modHigh = Math.round(maxHr * 0.7);
      const vigLow = Math.round(maxHr * 0.7);
      const vigHigh = Math.round(maxHr * 0.85);

      modEl.textContent = `${modLow}–${modHigh} bpm`;
      vigEl.textContent = `${vigLow}–${vigHigh} bpm`;
      result.classList.remove('hidden');
    });
  </script>
</ToolPageLayout>
