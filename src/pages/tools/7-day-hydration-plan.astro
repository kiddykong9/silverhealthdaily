---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import ToolSidebar from '../../components/ToolSidebar.astro';
---

<BaseLayout
  title="7-Day Hydration Plan"
  description="A one-week plan to build better hydration habits, one small step at a time."
>
  <section class="bg-gradient-to-br from-teal-600 to-emerald-700 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">7-Day Hydration Plan</h1>
      <p class="mt-2 text-white/85">Small daily goals that add up — no chugging required.</p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[1fr_280px]">
      <div>
        <div class="tool-panel">
          <div class="tool-panel-header">
            <p class="font-semibold text-white">Your starting point</p>
          </div>
          <div class="p-6">
            <form id="hyd-form" class="space-y-5">
              <div>
                <label for="glasses" class="form-label">Glasses of water per day now (estimate)</label>
                <input id="glasses" type="number" min="1" max="12" value="4" class="form-input" />
              </div>
              <div>
                <label for="target" class="form-label">Daily goal (glasses)</label>
                <input id="target" type="number" min="4" max="14" value="8" class="form-input" />
              </div>
              <button type="submit" class="form-submit">Generate hydration plan</button>
            </form>
            <ol id="hyd-list" class="mt-6 hidden space-y-3"></ol>
          </div>
        </div>
        <AdSlot slot="4444444444" class="mt-8" />
      </div>
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <ToolSidebar current="/tools/7-day-hydration-plan" />
      </aside>
    </div>
  </div>

  <script>
    const form = document.getElementById('hyd-form') as HTMLFormElement;
    const list = document.getElementById('hyd-list')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const current = Number((document.getElementById('glasses') as HTMLInputElement).value);
      const target = Number((document.getElementById('target') as HTMLInputElement).value);
      const step = (target - current) / 6;

      const days = [
        'Start with water at breakfast — before coffee or tea',
        'Keep a bottle on your desk or counter where you see it',
        'Add one glass at lunch',
        'Swap one sugary drink for water or herbal tea',
        'Drink a glass before each meal',
        'Include water-rich foods — cucumber, melon, soup',
        `Hit your goal of ${target} glasses — track in the habit tracker`,
      ];

      list.innerHTML = days
        .map((tip, i) => {
          const glasses = Math.round(current + step * i);
          return `<li class="rounded-xl border border-sage-200 bg-white px-4 py-3"><span class="font-semibold text-sage-900">Day ${i + 1}</span> — Aim for ~${glasses} glasses. ${tip}</li>`;
        })
        .join('');
      list.classList.remove('hidden');
    });
  </script>
</BaseLayout>
