---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import PageHero from '../../components/PageHero.astro';
import { TOOL_IMAGES, PAGE_HEROES } from '../../lib/media';
import { TOOLS, TOOL_IMAGES_MAP } from '../../lib/tools';
---

<BaseLayout
  title="Free Health Tools"
  description="Free calculators and planners for BMI, hydration, protein, sleep, walking, and daily wellness habits."
>
  <PageHero
    image={PAGE_HEROES.tools}
    label="Calculators & planners"
    title="Free health tools"
    description="Simple calculators and weekly plans to support everyday wellness. Results are estimates — not medical advice."
  />

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="mb-8 text-center">
      <a
        href="/start"
        class="inline-flex items-center gap-2 rounded-full bg-sage-700 px-6 py-3 text-sm font-semibold text-white transition hover:bg-sage-800"
      >
        Not sure where to start? Get a personalized plan
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        TOOLS.map((tool) => {
          const key = (TOOL_IMAGES_MAP[tool.href] ?? 'bmi') as keyof typeof TOOL_IMAGES;
          const img = TOOL_IMAGES[key];
          return (
            <ToolCard
              title={tool.title}
              description={tool.description}
              href={tool.href}
              image={img.src}
              imageAlt={img.alt}
            />
          );
        })
      }
    </div>
  </div>
</BaseLayout>
