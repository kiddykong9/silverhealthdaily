---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import PageHero from '../../components/PageHero.astro';
import { TOOL_IMAGES, PAGE_HEROES } from '../../lib/media';
import { TOOLS, TOOL_IMAGES_MAP } from '../../lib/tools';

const CATEGORY_LABELS: Record<string, string> = {
  nutrition: 'Nutrition & calories',
  body: 'Body composition',
  fitness: 'Fitness & walking',
  sleep: 'Sleep',
  'heart-health': 'Heart health',
  wellness: 'Daily habits',
};

const grouped = Object.groupBy(TOOLS, (t) => t.category);
const categoryOrder = ['nutrition', 'body', 'fitness', 'sleep', 'heart-health', 'wellness'];
---

<BaseLayout
  title="Free Health Calculators & Planners"
  description="18 free health calculators: BMI, TDEE, macros, protein, water intake, walking calories, sleep, and 7-day wellness plans."
  ogImage={PAGE_HEROES.tools.src.replace('w=1400', 'w=1200')}
>
  <PageHero
    image={PAGE_HEROES.tools}
    label="Calculators & planners"
    title="Free health calculators"
    description="BMI, calories, macros, hydration, walking, sleep, and weekly plans — instant results, no signup."
  />

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="mb-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/#program"
        class="inline-flex items-center gap-2 rounded-full bg-gold px-6 py-3 text-sm font-bold text-sage-900 transition hover:bg-gold-light"
      >
        Get your 7-Day Program
      </a>
      <a
        href="/start"
        class="inline-flex items-center gap-2 rounded-full border border-sage-300 px-6 py-3 text-sm font-semibold text-sage-800 transition hover:bg-sage-50"
      >
        Quick 3-question starter
      </a>
    </div>

    {
      categoryOrder.map((cat) => {
        const tools = grouped[cat];
        if (!tools?.length) return null;
        return (
          <section class="mb-14">
            <h2 class="font-display mb-6 text-2xl font-bold text-ink">
              {CATEGORY_LABELS[cat] ?? cat}
            </h2>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {tools.map((tool) => {
                const key = (TOOL_IMAGES_MAP[tool.href] ?? 'bmi') as keyof typeof TOOL_IMAGES;
                const img = TOOL_IMAGES[key];
                return (
                  <ToolCard
                    title={tool.title}
                    description={tool.description}
                    href={tool.href}
                    image={img.src}
                    imageAlt={img.alt}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>
</BaseLayout>
