---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import PageHero from '../../components/PageHero.astro';
import { TOOL_IMAGES, PAGE_HEROES } from '../../lib/media';
import { TOOLS, TOOL_IMAGES_MAP } from '../../lib/tools';

const CATEGORY_LABELS: Record<string, string> = {
  nutrition: 'Nutrition & calories',
  body: 'Body composition',
  fitness: 'Fitness & walking',
  sleep: 'Sleep',
  'heart-health': 'Heart health',
  wellness: 'Daily habits',
};

const grouped = Object.groupBy(TOOLS, (t) => t.category);
const categoryOrder = ['nutrition', 'body', 'fitness', 'sleep', 'heart-health', 'wellness'];
---

<BaseLayout
  title="Free Health Calculators — Walking Calories, Body Fat, BMI & TDEE"
  description="Free walking calorie calculator, body fat percentage calculator, BMI, TDEE, macros, and 18 health tools — instant results, no signup."
  ogImage={PAGE_HEROES.tools.src.replace('w=1400', 'w=1200')}
>
  <PageHero
    image={PAGE_HEROES.tools}
    label="Calculators & planners"
    title="Free health calculators"
    description="Calories burned walking, body fat percentage, BMI, daily calories, and more — instant results, no signup."
  />

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <section class="mb-12 rounded-2xl border border-sage-200 bg-gradient-to-br from-sage-50 to-cream p-6 sm:p-8">
      <h2 class="font-display text-xl font-bold text-sage-900">Popular calculators</h2>
      <p class="mt-1 text-sm text-muted">Most searched on Google — start here.</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/tools/walking-calorie-calculator/" class="btn-primary">Calories burned walking</a>
        <a href="/tools/body-fat-calculator/" class="btn-primary !bg-sage-800 hover:!bg-sage-900">Body fat calculator</a>
        <a href="/tools/daily-calorie-calculator/" class="rounded-full border border-sage-300 px-5 py-2.5 text-sm font-semibold text-sage-800 hover:bg-sage-50">Daily calories (TDEE)</a>
        <a href="/tools/step-goal-calculator/" class="rounded-full border border-sage-300 px-5 py-2.5 text-sm font-semibold text-sage-800 hover:bg-sage-50">Step goal</a>
        <a href="/tools/bmi-calculator/" class="rounded-full border border-sage-300 px-5 py-2.5 text-sm font-semibold text-sage-800 hover:bg-sage-50">BMI</a>
      </div>
    </section>

    <div class="mb-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/#program"
        class="inline-flex items-center gap-2 rounded-full bg-gold px-6 py-3 text-sm font-bold text-sage-900 transition hover:bg-gold-light"
      >
        Get your 7-Day Program
      </a>
      <a
        href="/start"
        class="inline-flex items-center gap-2 rounded-full border border-sage-300 px-6 py-3 text-sm font-semibold text-sage-800 transition hover:bg-sage-50"
      >
        Quick 3-question starter
      </a>
    </div>

    {
      categoryOrder.map((cat) => {
        const tools = grouped[cat];
        if (!tools?.length) return null;
        return (
          <section class="mb-14">
            <h2 class="font-display mb-6 text-2xl font-bold text-ink">
              {CATEGORY_LABELS[cat] ?? cat}
            </h2>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {tools.map((tool) => {
                const key = (TOOL_IMAGES_MAP[tool.href] ?? 'bmi') as keyof typeof TOOL_IMAGES;
                const img = TOOL_IMAGES[key];
                return (
                  <ToolCard
                    title={tool.title}
                    description={tool.description}
                    href={tool.href}
                    image={img.src}
                    imageAlt={img.alt}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>
</BaseLayout>
