---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
---

<BaseLayout
  title="Free Health Tools"
  description="Free BMI, water intake, and walking calorie calculators for adults 50+."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h1 class="mb-3 text-3xl font-bold text-stone-900">Free health tools</h1>
    <p class="mb-10 max-w-2xl text-stone-600">
      Simple calculators to support everyday wellness decisions. Results are estimates — not
      medical advice.
    </p>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <ToolCard
        title="BMI Calculator"
        description="Calculate body mass index and see general weight categories."
        href="/tools/bmi-calculator"
        icon="⚖️"
      />
      <ToolCard
        title="Water Intake Calculator"
        description="Estimate how much water to drink daily."
        href="/tools/water-intake-calculator"
        icon="💧"
      />
      <ToolCard
        title="Walking Calorie Calculator"
        description="Estimate calories burned while walking."
        href="/tools/walking-calorie-calculator"
        icon="🚶"
      />
    </div>
  </div>
</BaseLayout>
