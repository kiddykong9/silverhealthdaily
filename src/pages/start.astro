---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  FOCUS_OPTIONS,
  ACTIVITY_OPTIONS,
  INTEREST_OPTIONS,
  WIZARD_BASE,
  WIZARD_ACTIVITY_ARTICLE,
  WIZARD_INTEREST_ARTICLE,
} from '../lib/wizard';
import { TOOLS } from '../lib/tools';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articleData = allArticles.map((a) => ({
  id: a.id,
  title: a.data.title,
  description: a.data.description,
  category: a.data.category,
}));
const toolMap = Object.fromEntries(TOOLS.map((t) => [t.href, t]));
---

<BaseLayout
  title="Get Started — Your Personal Health Plan"
  description="Answer three quick questions and get a personalized reading list and tool recommendations."
>
  <section class="bg-gradient-to-br from-sage-700 to-sage-900 py-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-gold-light">Personalized for you</p>
      <h1 class="font-display mt-3 text-3xl font-bold text-white sm:text-4xl">Find your starting point</h1>
      <p class="mt-3 text-lg text-white/85">
        Three quick questions — then articles and tools matched to your goals.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <div id="wizard" class="space-y-8">
      <div data-step="1" class="wizard-step">
        <h2 class="font-display text-xl font-bold text-sage-900">What matters most right now?</h2>
        <div class="mt-4 grid gap-3">
          {
            FOCUS_OPTIONS.map((opt) => (
              <button
                type="button"
                data-focus={opt.id}
                class="wizard-choice rounded-xl border border-sage-200 bg-white px-5 py-4 text-left transition hover:border-sage-400 hover:bg-sage-50"
              >
                <span class="block font-semibold text-ink">{opt.label}</span>
                <span class="text-sm text-muted">{opt.desc}</span>
              </button>
            ))
          }
        </div>
      </div>

      <div data-step="2" class="wizard-step hidden">
        <h2 class="font-display text-xl font-bold text-sage-900">How active are you today?</h2>
        <div class="mt-4 grid gap-3">
          {
            ACTIVITY_OPTIONS.map((opt) => (
              <button
                type="button"
                data-activity={opt.id}
                class="wizard-choice rounded-xl border border-sage-200 bg-white px-5 py-4 text-left font-medium text-ink transition hover:border-sage-400 hover:bg-sage-50"
              >
                {opt.label}
              </button>
            ))
          }
        </div>
      </div>

      <div data-step="3" class="wizard-step hidden">
        <h2 class="font-display text-xl font-bold text-sage-900">What do you want to focus on?</h2>
        <div class="mt-4 grid gap-3">
          {
            INTEREST_OPTIONS.map((opt) => (
              <button
                type="button"
                data-interest={opt.id}
                class="wizard-choice rounded-xl border border-sage-200 bg-white px-5 py-4 text-left font-medium text-ink transition hover:border-sage-400 hover:bg-sage-50"
              >
                {opt.label}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <div id="wizard-result" class="hidden">
      <div class="rounded-2xl bg-sage-50 px-6 py-8 text-center">
        <h2 id="result-title" class="font-display text-2xl font-bold text-sage-900"></h2>
        <p id="result-summary" class="mt-2 text-ink-soft"></p>
      </div>

      <h3 class="font-display mt-10 text-xl font-bold text-sage-900">Recommended reads</h3>
      <div id="result-articles" class="mt-4 grid gap-6 sm:grid-cols-2"></div>

      <h3 class="font-display mt-10 text-xl font-bold text-sage-900">Tools to try</h3>
      <div id="result-tools" class="mt-4 grid gap-5 sm:grid-cols-2"></div>

      <p class="mt-10 text-center">
        <button type="button" class="text-sm font-semibold text-sage-700 hover:text-sage-900" id="restart">
          Start over
        </button>
      </p>
    </div>
  </div>

  <script
    define:vars={{
      articleData,
      toolMap,
      wizardBase: WIZARD_BASE,
      activityArticle: WIZARD_ACTIVITY_ARTICLE,
      interestArticle: WIZARD_INTEREST_ARTICLE,
    }}
  >
    let focus = '';
    let activity = '';
    let interest = '';

    function buildPlan(f, a, i) {
      const base = wizardBase[f];
      const articles = [...new Set([...base.articles, activityArticle[a], interestArticle[i]])].slice(0, 5);
      return { title: base.title, summary: base.summary, articles, tools: base.tools };
    }

    function showStep(n) {
      document.querySelectorAll('.wizard-step').forEach((el) => {
        el.classList.toggle('hidden', Number(el.dataset.step) !== n);
      });
    }

    document.querySelectorAll('[data-focus]').forEach((btn) => {
      btn.addEventListener('click', () => {
        focus = btn.dataset.focus;
        showStep(2);
      });
    });

    document.querySelectorAll('[data-activity]').forEach((btn) => {
      btn.addEventListener('click', () => {
        activity = btn.dataset.activity;
        showStep(3);
      });
    });

    document.querySelectorAll('[data-interest]').forEach((btn) => {
      btn.addEventListener('click', () => {
        interest = btn.dataset.interest;
        renderResult();
      });
    });

    function renderResult() {
      const plan = buildPlan(focus, activity, interest);
      document.getElementById('wizard').classList.add('hidden');
      document.getElementById('wizard-result').classList.remove('hidden');
      document.getElementById('result-title').textContent = plan.title;
      document.getElementById('result-summary').textContent = plan.summary;

      const matched = plan.articles.map((id) => articleData.find((a) => a.id === id)).filter(Boolean);

      document.getElementById('result-articles').innerHTML = matched
        .map(
          (a) => `
        <a href="/articles/${a.id}" class="group block overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-sage-100 transition hover:shadow-lg">
          <div class="p-5">
            <p class="text-xs font-semibold uppercase text-sage-600">${a.category.replace('-', ' ')}</p>
            <h4 class="font-display mt-1 font-bold text-sage-900 group-hover:text-sage-700">${a.title}</h4>
            <p class="mt-2 text-sm text-muted line-clamp-2">${a.description}</p>
          </div>
        </a>`,
        )
        .join('');

      document.getElementById('result-tools').innerHTML = plan.tools
        .map((href) => {
          const t = toolMap[href];
          if (!t) return '';
          return `
        <a href="${href}" class="block rounded-xl border border-sage-200 bg-white px-5 py-4 transition hover:border-sage-400 hover:bg-sage-50">
          <span class="font-semibold text-sage-900">${t.title}</span>
          <span class="mt-1 block text-sm text-muted">${t.description}</span>
        </a>`;
        })
        .join('');
    }

    document.getElementById('restart')?.addEventListener('click', () => location.reload());
  </script>
</BaseLayout>
