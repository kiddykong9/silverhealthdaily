---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../lib/site';

const GUMROAD_URL = import.meta.env.PUBLIC_GUMROAD_PLAN_URL ?? '';
const PRICE = import.meta.env.PUBLIC_PLAN_PRICE ?? '$9';
---

<BaseLayout
  title="Personal Health Plan — Custom PDF Report"
  description="Answer a guided survey about your goals, body metrics, sleep, and nutrition. Get a personalized multi-page health plan PDF powered by all Silver Health Daily calculators."
  ogImage={SITE.defaultOgImage}
>
  <section class="bg-gradient-to-br from-sage-700 to-sage-900 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-gold-light">Digital product</p>
      <h1 class="font-display mt-3 text-3xl font-bold text-white sm:text-4xl">
        Your Personal Health Plan
      </h1>
      <p class="mt-4 text-lg text-white/85">
        A full survey → a custom PDF with calorie targets, macros, hydration, walking plan, sleep
        schedule, and tool recommendations — built from our entire calculator suite.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/personal-health-plan/survey"
          class="rounded-full bg-gold px-8 py-3.5 text-sm font-bold text-sage-900 shadow-lg transition hover:bg-gold-light"
        >
          Start the survey
        </a>
        {
          GUMROAD_URL && (
            <a
              href={GUMROAD_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border-2 border-white/40 px-8 py-3.5 text-sm font-bold text-white transition hover:bg-white/10"
            >
              Get access — {PRICE}
            </a>
          )
        }
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 py-14 sm:px-6">
    <h2 class="font-display text-center text-2xl font-bold text-sage-900">What's inside your PDF</h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        [
          {
            title: 'Body & energy',
            desc: 'BMI, healthy weight range, BMR, TDEE, and a safe calorie target for your goal.',
          },
          {
            title: 'Nutrition',
            desc: 'Daily protein, macro split, and meal-by-meal calorie breakdown.',
          },
          {
            title: 'Hydration',
            desc: 'Oz-per-day target plus a 7-day hydration habit plan.',
          },
          {
            title: 'Movement',
            desc: 'Step goal, walking calories, heart-rate zones, and a 7-day walking schedule.',
          },
          {
            title: 'Sleep',
            desc: 'Bedtime options from your wake time and a tailored 7-day sleep plan.',
          },
          {
            title: 'Resources',
            desc: 'Links to all 16+ free tools and articles matched to your primary goal.',
          },
        ].map((item) => (
          <div class="rounded-2xl border border-sage-100 bg-white p-6 shadow-sm">
            <h3 class="font-display font-bold text-sage-900">{item.title}</h3>
            <p class="mt-2 text-sm text-muted">{item.desc}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-14 rounded-2xl bg-sage-50 px-6 py-8 text-center">
      <h2 class="font-display text-xl font-bold text-sage-900">How it works</h2>
      <ol class="mx-auto mt-6 max-w-lg space-y-4 text-left text-sm text-ink-soft">
        <li>
          <span class="font-bold text-sage-800">1.</span> Complete the 6-step survey (about 5 minutes)
        </li>
        <li>
          <span class="font-bold text-sage-800">2.</span> Review your personalized plan on screen
        </li>
        <li>
          <span class="font-bold text-sage-800">3.</span> Download a polished PDF to save or print
        </li>
      </ol>
      <a
        href="/personal-health-plan/survey"
        class="mt-8 inline-block rounded-full bg-sage-700 px-8 py-3 text-sm font-bold text-white transition hover:bg-sage-800"
      >
        Begin survey →
      </a>
    </div>

    <p class="mt-10 text-center text-xs text-muted">
      For educational purposes only — not medical advice. Always consult your healthcare provider
      before starting a new diet or exercise program.
    </p>
  </div>
</BaseLayout>
