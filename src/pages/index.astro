---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ToolCard from '../components/ToolCard.astro';
import HeroMedia from '../components/HeroMedia.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import VideoShowcase from '../components/VideoShowcase.astro';
import CategoryCard from '../components/CategoryCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { SITE, CATEGORIES, TRUST_POINTS } from '../lib/site';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const featured = articles.filter((a) => a.data.featured).slice(0, 3);
const latest = articles.slice(0, 6);
const articleCount = articles.length;
---

<BaseLayout>
  <HeroMedia />

  <!-- Trust bar -->
  <section class="border-y border-sage-100 bg-white/80 backdrop-blur-sm">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-10 gap-y-3 px-4 py-5 sm:px-6">
      {
        TRUST_POINTS.map((point, i) => (
          <span
            class="trust-item flex items-center gap-2 text-sm font-medium text-ink-soft"
            style={`animation-delay: ${i * 100}ms`}
          >
            <svg class="h-4 w-4 text-sage-600" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
            {point}
          </span>
        ))
      }
    </div>
  </section>

  <AdSlot slot="3333333333" format="horizontal" class="mx-auto max-w-6xl px-4 pt-10" />

  <!-- Categories with photos -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    <ScrollReveal>
      <SectionHeading
        label="Explore topics"
        title="What would you like to feel better about?"
        description="Real photo guides on nutrition, movement, sleep, and more — steps you can take today."
      />
    </ScrollReveal>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {CATEGORIES.map((cat, i) => (
        <ScrollReveal delay={i * 80}>
          <CategoryCard slug={cat.slug} />
        </ScrollReveal>
      ))}
    </div>
  </section>

  <PhotoGallery />

  <VideoShowcase />

  <!-- Featured -->
  {
    featured.length > 0 && (
      <section class="bg-sage-900 py-16 lg:py-20">
        <div class="mx-auto max-w-6xl px-4 sm:px-6">
          <ScrollReveal>
            <SectionHeading
              label="Editor's picks"
              title="Start with these guides"
              description="Our most helpful reads for staying active, eating well, and protecting your heart."
              dark
            />
          </ScrollReveal>
          <div class="grid gap-6 md:grid-cols-3">
            {featured.map((article, i) => (
              <ScrollReveal delay={i * 100}>
                <ArticleCard article={article} featured />
              </ScrollReveal>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Latest -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    <ScrollReveal>
      <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
        <SectionHeading label="Fresh reads" title="Latest articles" />
        <a
          href="/articles"
          class="inline-flex items-center gap-1 text-sm font-semibold text-sage-700 hover:text-sage-900"
        >
          View all {articleCount} articles
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </ScrollReveal>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {latest.map((article, i) => (
        <ScrollReveal delay={i * 60}>
          <ArticleCard article={article} />
        </ScrollReveal>
      ))}
    </div>
  </section>

  <!-- Tools -->
  <section class="border-t border-sage-100 bg-gradient-to-b from-cream-dark to-cream py-16 lg:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <ScrollReveal>
        <SectionHeading
          label="Free tools"
          title="Quick answers, no signup"
          description="Handy calculators for BMI, hydration, and walking calories."
          centered
        />
      </ScrollReveal>
      <div class="grid gap-5 md:grid-cols-3">
        <ScrollReveal delay={0}>
          <ToolCard
            title="BMI Calculator"
            description="Check your body mass index with context that makes sense after 50."
            href="/tools/bmi-calculator"
            icon="⚖️"
            accent="from-emerald-600 to-teal-700"
            image="https://images.unsplash.com/photo-1571019614242-c5c5dee996f8?auto=format&fit=crop&w=600&q=80"
          />
        </ScrollReveal>
        <ScrollReveal delay={100}>
          <ToolCard
            title="Water Intake"
            description="Estimate how much water your body needs daily."
            href="/tools/water-intake-calculator"
            icon="💧"
            accent="from-sky-600 to-blue-700"
            image="https://images.unsplash.com/photo-1548839140-5a941f994e83?auto=format&fit=crop&w=600&q=80"
          />
        </ScrollReveal>
        <ScrollReveal delay={200}>
          <ToolCard
            title="Walking Calories"
            description="See how much your daily walk is doing for your health."
            href="/tools/walking-calorie-calculator"
            icon="🚶"
            accent="from-amber-500 to-orange-600"
            image="https://images.unsplash.com/photo-1476480862126-209bf4358eba?auto=format&fit=crop&w=600&q=80"
          />
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- CTA with background photo -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <ScrollReveal>
      <div class="relative overflow-hidden rounded-3xl shadow-2xl">
        <img
          src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=1200&q=80"
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          aria-hidden="true"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-sage-900/95 to-sage-900/75" />
        <div class="relative px-8 py-14 text-center sm:px-16 sm:py-16">
          <p class="section-label !text-gold-light">Stay informed</p>
          <h2 class="font-display mx-auto max-w-xl text-3xl font-bold text-white sm:text-4xl">
            Health is a daily habit — we're here every step
          </h2>
          <p class="mx-auto mt-4 max-w-lg text-sage-200">
            Bookmark {SITE.name} and check back for new guides. Your future self will thank you.
          </p>
          <a href="/articles" class="btn-primary mt-8 !bg-white !text-sage-800 !shadow-none hover:!bg-cream">
            Explore all articles
          </a>
        </div>
      </div>
    </ScrollReveal>
  </section>
</BaseLayout>
