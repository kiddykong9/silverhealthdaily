---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ToolCard from '../components/ToolCard.astro';
import { getCollection } from 'astro:content';
import { SITE, CATEGORIES } from '../lib/site';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const featured = articles.filter((a) => a.data.featured).slice(0, 3);
const latest = articles.slice(0, 6);
---

<BaseLayout>
  <section class="bg-gradient-to-b from-brand-50 to-surface">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-brand-700">
        Health for adults 50+
      </p>
      <h1 class="max-w-3xl text-4xl font-bold leading-tight text-stone-900 sm:text-5xl">
        Daily health tips you can actually use
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-stone-600">
        {SITE.description} Browse guides on nutrition, fitness, sleep, and heart health — plus
        free calculators.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/articles"
          class="rounded-full bg-brand-600 px-6 py-3 font-semibold text-white hover:bg-brand-700"
        >
          Browse articles
        </a>
        <a
          href="/tools"
          class="rounded-full border border-brand-300 bg-white px-6 py-3 font-semibold text-brand-800 hover:bg-brand-50"
        >
          Try free tools
        </a>
      </div>
    </div>
  </section>

  <AdSlot slot="3333333333" format="horizontal" class="mx-auto max-w-6xl px-4" />

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <h2 class="mb-8 text-2xl font-bold text-stone-900">Popular topics</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        CATEGORIES.map((cat) => (
          <a
            href={`/category/${cat.slug}`}
            class="rounded-2xl border border-stone-200 bg-white p-6 transition hover:border-brand-200 hover:shadow-md"
          >
            <h3 class="text-lg font-bold text-brand-800">{cat.name}</h3>
            <p class="mt-2 text-sm text-stone-600">{cat.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="border-y border-stone-200 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
          <h2 class="mb-8 text-2xl font-bold text-stone-900">Featured guides</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {featured.map((article) => (
              <ArticleCard article={article} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="mb-8 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold text-stone-900">Latest articles</h2>
      <a href="/articles" class="text-sm font-semibold text-brand-700 hover:underline">
        View all →
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {latest.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="border-t border-stone-200 bg-brand-50">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <h2 class="mb-8 text-2xl font-bold text-stone-900">Free health tools</h2>
      <p class="mb-8 max-w-2xl text-stone-600">
        Quick calculators that answer common questions — great for search and repeat visits.
      </p>
      <div class="grid gap-4 md:grid-cols-3">
        <ToolCard
          title="BMI Calculator"
          description="Check your body mass index with age-appropriate context."
          href="/tools/bmi-calculator"
          icon="⚖️"
        />
        <ToolCard
          title="Water Intake Calculator"
          description="Estimate daily hydration needs based on weight and activity."
          href="/tools/water-intake-calculator"
          icon="💧"
        />
        <ToolCard
          title="Walking Calorie Calculator"
          description="See calories burned from walking by pace, weight, and duration."
          href="/tools/walking-calorie-calculator"
          icon="🚶"
        />
      </div>
    </div>
  </section>
</BaseLayout>
